    <sys:String x:Key="Tip.ResumeQueue">Resume a paused TTS queue and continue playing items.</sys:String>
    <sys:String x:Key="Tip.SkipCurrent">Skip the currently playing TTS audio.</sys:String>
    <sys:String x:Key="Tip.ClearQueue">Remove all pending items from the TTS queue.</sys:String>

    <!-- Users tab -->
    <sys:String x:Key="Tip.HideNotPresent">Only show users who have sent a chat message in the last hour.</sys:String>
    <sys:String x:Key="Tip.UserVoiceAlias">Assign a specific voice alias to this user, overriding the default voice.</sys:String>
    <sys:String x:Key="Tip.UserNickname">Set a nickname to be spoken instead of their Twitch username.</sys:String>
    <sys:String x:Key="Tip.UserIgnored">Ignored users are never read by TTS, regardless of any other permissions.</sys:String>
    <sys:String x:Key="Tip.UserForced">Forced users always have their messages read, bypassing all permission checks.</sys:String>
    <sys:String x:Key="Tip.UserRegular">Regulars are treated as trusted users when the Regular permission tier is enabled.</sys:String>
    <sys:String x:Key="Tip.UserSubscribed">Marks this user as a subscriber. Usually updated automatically from Twitch.</sys:String>
    <sys:String x:Key="Tip.SaveUser">Save changes to this user's settings.</sys:String>

    <!-- Events tab -->
    <sys:String x:Key="Tip.EventsGlobalEnabled">Enable or disable all Twitch event TTS announcements globally.</sys:String>
    <sys:String x:Key="Tip.GlobalVoiceAlias">Voice alias used for all event announcements, unless overridden per event.</sys:String>
