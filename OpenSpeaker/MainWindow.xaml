                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="50"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>

                                <TextBlock Grid.Row="0" Grid.Column="0" Text="{DynamicResource Lbl.AvailableVoices}"
                                           Style="{DynamicResource SectionLabel}" Margin="0,0,0,4"/>
                                <TextBlock Grid.Row="0" Grid.Column="2" Text="{DynamicResource Lbl.IgnoredVoicesList}"
                                           Style="{DynamicResource SectionLabel}" Margin="0,0,0,4"/>

