                                        <DataTemplate><TextBlock Text="{Binding}" Padding="2,1" FontSize="12"/></DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                            </Grid>

                            <Grid Grid.Column="2">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <TextBlock Grid.Row="0" Text="{DynamicResource Lbl.AvailableLocales}" Style="{DynamicResource SectionLabel}" Margin="0,0,0,4"/>
                                <ListBox Grid.Row="1" ItemsSource="{Binding IgnoredVoices.AvailableLocales}"
                                         SelectedItem="{Binding IgnoredVoices.SelectedAvailableLocale}">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate><TextBlock Text="{Binding}" Padding="2,1" FontSize="12"/></DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>

                                <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,4">
                                    <Button Content="{DynamicResource Btn.IgnoreLocale}" Command="{Binding IgnoredVoices.IgnoreLocaleCommand}"
                                            Margin="0,0,4,0" ToolTip="{DynamicResource Tip.IgnoreLocale}"/>
                                    <Button Content="{DynamicResource Btn.UnignoreLocale}" Command="{Binding IgnoredVoices.UnignoreLocaleCommand}"
                                            ToolTip="{DynamicResource Tip.UnignoreLocale}"/>
                                </StackPanel>

                                <ListBox Grid.Row="3" ItemsSource="{Binding IgnoredVoices.IgnoredLocales}"
                                         SelectedItem="{Binding IgnoredVoices.SelectedIgnoredLocale}">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate><TextBlock Text="{Binding}" Padding="2,1" FontSize="12"/></DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>

                                <Border Grid.Row="4" Background="{DynamicResource Bg3}" CornerRadius="4" Padding="8,6" Margin="0,8,0,0">
                                    <StackPanel>
                                        <TextBlock Text="{DynamicResource Section.Profiles}" Style="{DynamicResource SectionLabel}" Margin="0,0,0,6"/>
                                        <ComboBox ItemsSource="{Binding IgnoredVoices.Profiles}"
                                                  SelectedItem="{Binding IgnoredVoices.SelectedProfile}"
                                                  Margin="0,0,0,6">
                                            <ComboBox.ItemTemplate>
                                                <DataTemplate>
                                                    <TextBlock Text="{Binding Name}"/>
                                                </DataTemplate>
                                            </ComboBox.ItemTemplate>
                                        </ComboBox>
                                        <TextBox Text="{Binding IgnoredVoices.NewProfileName}" Margin="0,0,0,6"/>
                                        <StackPanel Orientation="Horizontal">
                                            <Button Content="{DynamicResource Btn.New}" Command="{Binding IgnoredVoices.NewProfileCommand}"
                                                    Margin="0,0,4,0" ToolTip="{DynamicResource Tip.NewVoiceProfile}"/>
                                            <Button Content="{DynamicResource Btn.Delete}" Command="{Binding IgnoredVoices.DeleteProfileCommand}"
                                                    Style="{DynamicResource DangerButton}"
                                                    ToolTip="{DynamicResource Tip.DeleteVoiceProfile}"/>
                                        </StackPanel>
                                    </StackPanel>
                                </Border>
                            </Grid>
                        </Grid>
                    </TabItem>

                    <!-- ─── Speaking Options ─── -->
                    <TabItem Header="{DynamicResource Tab.SpeakingOptions}">
                        <ScrollViewer Padding="16">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="16"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0">
                                    <GroupBox Header="{StaticResource Section.SpeakingMode}" Margin="0,0,0,12">
                                        <StackPanel>
                                            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                                <TextBlock Text="{DynamicResource Lbl.Mode}" Style="{DynamicResource MutedText}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                                <ComboBox ItemsSource="{Binding SpeakingOptions.AvailableModes}"
                                                          SelectedItem="{Binding SpeakingOptions.Mode}" Width="120"
                                                          ToolTip="{DynamicResource Tip.SpeakingMode}"/>
                                            </StackPanel>
                                            <CheckBox Content="{DynamicResource Chk.SayUsername}" IsChecked="{Binding SpeakingOptions.SayUsername}"
                                                      Margin="0,0,0,6" ToolTip="{DynamicResource Tip.SayUsername}"/>
                                            <StackPanel Orientation="Horizontal" Margin="20,0,0,8">
                                                <TextBlock Text="{DynamicResource Lbl.Postfix}" Style="{DynamicResource MutedText}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                                <TextBox Text="{Binding SpeakingOptions.SayUsernamePrefix}" Width="80"
                                                         ToolTip="{DynamicResource Tip.UsernamePostfix}"/>
                                            </StackPanel>
                                            <CheckBox Content="{DynamicResource Chk.StickyRandomVoice}" IsChecked="{Binding SpeakingOptions.StickyRandomVoice}"
                                                      Margin="0,0,0,8" ToolTip="{DynamicResource Tip.StickyRandomVoice}"/>
                                            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                                <CheckBox Content="{DynamicResource Lbl.HighlightVoiceAliasSuffix}" IsChecked="{Binding SpeakingOptions.UseHighlightVoice}"
                                                          VerticalAlignment="Center" Margin="0,0,6,0"
                                                          ToolTip="{DynamicResource Tip.UseHighlightVoice2}"/>
                                                <ComboBox ItemsSource="{Binding SpeakingOptions.AvailableAliases}"
                                                          SelectedItem="{Binding SpeakingOptions.HighlightVoiceAlias}" Width="120"
                                                          ToolTip="{DynamicResource Tip.HighlightVoiceAliasInput}"/>
                                            </StackPanel>
                                            <CheckBox Content="{DynamicResource Chk.OnlySayUsernameIfDifferent}" IsChecked="{Binding SpeakingOptions.OnlySayUsernameIfDifferent}"
                                                      Margin="0,0,0,8" ToolTip="{DynamicResource Tip.OnlySayUsernameIfDifferent}"/>
                                            <CheckBox Content="{DynamicResource Chk.ReplaceNameWithNickname}" IsChecked="{Binding SpeakingOptions.ReplaceNameWithNickname}"
                                                      Margin="0,0,0,8" ToolTip="{DynamicResource Tip.ReplaceNameWithNickname}"/>
                                        </StackPanel>
                                    </GroupBox>

                                    <GroupBox Header="{StaticResource Section.Limits}" Margin="0,0,0,12">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="140"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="8"/>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="8"/>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="8"/>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="8"/>
                                                <RowDefinition Height="Auto"/>
                                            </Grid.RowDefinitions>
                                            <TextBlock Grid.Row="0" Grid.Column="0" Text="{DynamicResource Lbl.Cooldown}" Style="{DynamicResource MutedText}" VerticalAlignment="Center"/>
                                            <StackPanel Grid.Row="0" Grid.Column="1" Orientation="Horizontal">
                                                <TextBox Text="{Binding SpeakingOptions.CooldownSeconds}" Width="60"
                                                         ToolTip="{DynamicResource Tip.CooldownSeconds}"/>
                                                <TextBlock Text="{DynamicResource Lbl.SecondsPerUser}" Style="{DynamicResource MutedText}" VerticalAlignment="Center" Margin="8,0,0,0"/>
                                            </StackPanel>
                                            <TextBlock Grid.Row="2" Grid.Column="0" Text="{DynamicResource Lbl.MaxWords}" Style="{DynamicResource MutedText}" VerticalAlignment="Center"/>
                                            <StackPanel Grid.Row="2" Grid.Column="1" Orientation="Horizontal">
                                                <TextBox Text="{Binding SpeakingOptions.MaxWords}" Width="60"
                                                         ToolTip="{DynamicResource Tip.MaxWords}"/>
                                                <CheckBox Content="{DynamicResource Chk.TreatSymbolsAsSpaces}" IsChecked="{Binding SpeakingOptions.WordLimitSymbolsAsSpaces}"
                                                          VerticalAlignment="Center" Margin="12,0,0,0"
                                                          ToolTip="{DynamicResource Tip.TreatSymbolsAsSpaces}"/>
                                            </StackPanel>
                                            <TextBlock Grid.Row="4" Grid.Column="0" Text="{DynamicResource Lbl.MaxChars}" Style="{DynamicResource MutedText}" VerticalAlignment="Center"/>
                                            <StackPanel Grid.Row="4" Grid.Column="1" Orientation="Horizontal">
                                                <TextBox Text="{Binding SpeakingOptions.MaxChars}" Width="60"
                                                         ToolTip="{DynamicResource Tip.MaxChars}"/>
                                            </StackPanel>
                                            <TextBlock Grid.Row="6" Grid.Column="0" Text="{DynamicResource Lbl.UrlFilter}" Style="{DynamicResource MutedText}" VerticalAlignment="Center"/>
                                            <ComboBox Grid.Row="6" Grid.Column="1"
                                                      ItemsSource="{Binding SpeakingOptions.UrlFilterModes}"
                                                      SelectedItem="{Binding SpeakingOptions.UrlFilterMode}"
                                                      ToolTip="{DynamicResource Tip.UrlFilterMode}"/>
                                            <TextBlock Grid.Row="8" Grid.Column="0" Text="{DynamicResource Lbl.NotAllowedText}" Style="{DynamicResource MutedText}" VerticalAlignment="Center"/>
                                            <TextBox Grid.Row="8" Grid.Column="1" Text="{Binding SpeakingOptions.NotAllowedText}"
                                                     ToolTip="{DynamicResource Tip.NotAllowedText}"/>
                                        </Grid>
                                    </GroupBox>

                                    <GroupBox Header="{StaticResource Section.StopSkipOn}" Margin="0,0,0,12">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                            </Grid.RowDefinitions>
                                            <TextBlock Grid.Row="0" Grid.Column="1" Text="{DynamicResource Col.Stop}" Style="{DynamicResource MutedText}" Margin="0,0,0,4"/>
                                            <TextBlock Grid.Row="0" Grid.Column="2" Text="{DynamicResource Col.Skip}" Style="{DynamicResource MutedText}" Margin="8,0,0,4"/>
                                            <TextBlock Grid.Row="1" Grid.Column="0" Text="{DynamicResource Lbl.MessageDeleted}" Style="{DynamicResource MutedText}" VerticalAlignment="Center" Margin="0,0,0,6"/>
                                            <CheckBox Grid.Row="1" Grid.Column="1" IsChecked="{Binding SpeakingOptions.StopOnMessageDeleted}"
                                                      Margin="0,0,0,6" ToolTip="{DynamicResource Tip.StopOnMsgDeleted}"/>
                                            <CheckBox Grid.Row="1" Grid.Column="2" IsChecked="{Binding SpeakingOptions.SkipOnMessageDeleted}"
                                                      Margin="8,0,0,6" ToolTip="{DynamicResource Tip.SkipOnMsgDeleted}"/>
                                            <TextBlock Grid.Row="2" Grid.Column="0" Text="{DynamicResource Lbl.UserTimedOut}" Style="{DynamicResource MutedText}" VerticalAlignment="Center" Margin="0,0,0,6"/>
                                            <CheckBox Grid.Row="2" Grid.Column="1" IsChecked="{Binding SpeakingOptions.StopOnUserTimedOut}"
                                                      Margin="0,0,0,6" ToolTip="{DynamicResource Tip.StopOnTimedOut}"/>
                                            <CheckBox Grid.Row="2" Grid.Column="2" IsChecked="{Binding SpeakingOptions.SkipOnUserTimedOut}"
                                                      Margin="8,0,0,6" ToolTip="{DynamicResource Tip.SkipOnTimedOut}"/>
                                            <TextBlock Grid.Row="3" Grid.Column="0" Text="{DynamicResource Lbl.UserBanned}" Style="{DynamicResource MutedText}" VerticalAlignment="Center"/>
                                            <CheckBox Grid.Row="3" Grid.Column="1" IsChecked="{Binding SpeakingOptions.StopOnUserBanned}"
                                                      ToolTip="{DynamicResource Tip.StopOnBanned}"/>
                                            <CheckBox Grid.Row="3" Grid.Column="2" IsChecked="{Binding SpeakingOptions.SkipOnUserBanned}"
                                                      Margin="8,0,0,0" ToolTip="{DynamicResource Tip.SkipOnBanned}"/>
                                        </Grid>
                                    </GroupBox>

                                    <GroupBox Header="{StaticResource Section.Permissions}" Margin="0,0,0,12">
                                        <StackPanel>
                                            <CheckBox Content="{DynamicResource Chk.Moderators}" IsChecked="{Binding SpeakingOptions.AllowModerators}"
                                                      Margin="0,0,0,6" ToolTip="{DynamicResource Tip.AllowModerators}"/>
                                            <CheckBox Content="{DynamicResource Chk.Subscribers}" IsChecked="{Binding SpeakingOptions.AllowSubscribers}"
                                                      Margin="0,0,0,6" ToolTip="{DynamicResource Tip.AllowSubscribers}"/>
                                            <CheckBox Content="{DynamicResource Chk.VIPs}" IsChecked="{Binding SpeakingOptions.AllowVIPs}"
                                                      Margin="0,0,0,6" ToolTip="{DynamicResource Tip.AllowVips}"/>
                                            <CheckBox Content="{DynamicResource Chk.Regulars}" IsChecked="{Binding SpeakingOptions.AllowRegulars}"
                                                      Margin="0,0,0,6" ToolTip="{DynamicResource Tip.AllowRegulars}"/>
                                            <CheckBox Content="{DynamicResource Chk.Everyone}" IsChecked="{Binding SpeakingOptions.AllowEveryone}"
                                                      ToolTip="{DynamicResource Tip.AllowEveryone}"/>
                                        </StackPanel>
                                    </GroupBox>

                                    <GroupBox Header="{StaticResource Section.CommandOptions}">
                                        <CheckBox Content="{DynamicResource Chk.SilenceCommandOutput}" IsChecked="{Binding SpeakingOptions.SilenceCommandOutput}"
                                                  ToolTip="{DynamicResource Tip.SilenceCommandOutput}"/>
                                    </GroupBox>
                                </StackPanel>

                                <StackPanel Grid.Column="2">
                                    <GroupBox Header="{StaticResource Section.Emotes}" Margin="0,0,0,12">
                                        <StackPanel>
                                            <CheckBox Content="{DynamicResource Chk.IgnoreTwitchEmotes}" IsChecked="{Binding SpeakingOptions.StripTwitchEmotes}"
                                                      Margin="0,0,0,6" ToolTip="{DynamicResource Tip.IgnoreTwitchEmotes}"/>
                                            <CheckBox Content="{DynamicResource Chk.IgnoreBttvEmotes}" IsChecked="{Binding SpeakingOptions.StripBttvEmotes}"
                                                      Margin="0,0,0,6" ToolTip="{DynamicResource Tip.IgnoreBttvEmotes}"/>
                                            <CheckBox Content="{DynamicResource Chk.IgnoreFfzEmotes}" IsChecked="{Binding SpeakingOptions.StripFfzEmotes}"
                                                      Margin="0,0,0,6" ToolTip="{DynamicResource Tip.IgnoreFfzEmotes}"/>
                                            <CheckBox Content="{DynamicResource Chk.IgnoreSevenTvEmotes}" IsChecked="{Binding SpeakingOptions.StripSevenTvEmotes}"
                                                      Margin="0,0,0,6" ToolTip="{DynamicResource Tip.IgnoreSevenTvEmotes}"/>
                                            <CheckBox Content="{DynamicResource Chk.IgnoreTwemoji}" IsChecked="{Binding SpeakingOptions.StripTwemoji}"
                                                      Margin="0,0,0,6" ToolTip="{DynamicResource Tip.IgnoreTwemoji}"/>
                                            <CheckBox Content="{DynamicResource Chk.IgnoreCheermotes}" IsChecked="{Binding SpeakingOptions.StripCheermotes}"
                                                      Margin="0,0,0,6" ToolTip="{DynamicResource Tip.IgnoreCheermotes}"/>
                                            <CheckBox Content="{DynamicResource Chk.AllowFirstEmote}" IsChecked="{Binding SpeakingOptions.AllowFirstEmote}"
                                                      Margin="0,0,0,8" ToolTip="{DynamicResource Tip.AllowFirstEmote}"/>
                                            <Button Content="Refresh Emotes" Command="{Binding SpeakingOptions.RefreshEmotesCommand}"
                                                    HorizontalAlignment="Left" Margin="0,0,0,8"/>
                                            <TextBlock Text="{DynamicResource Section.AllowedEmotes}" Style="{DynamicResource SectionLabel}" Margin="0,4,0,4"/>
                                            <ListBox ItemsSource="{Binding SpeakingOptions.AllowedEmotes}"
                                                     SelectedItem="{Binding SpeakingOptions.SelectedAllowedEmote}"
                                                     Height="80" BorderThickness="0" Background="{DynamicResource Bg3}">
                                                <ListBox.ItemTemplate>
                                                    <DataTemplate><TextBlock Text="{Binding}" FontSize="12"/></DataTemplate>
                                                </ListBox.ItemTemplate>
                                            </ListBox>
                                            <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                                <TextBox Text="{Binding SpeakingOptions.NewAllowedEmote}" Width="120" Margin="0,0,6,0"/>
                                                <Button Content="{DynamicResource Btn.Add}" Command="{Binding SpeakingOptions.AddEmoteCommand}"
                                                        Margin="0,0,4,0" ToolTip="{DynamicResource Tip.AddAllowedEmote}"/>
                                                <Button Content="{DynamicResource Btn.Del}" Command="{Binding SpeakingOptions.DeleteEmoteCommand}"
                                                        Style="{DynamicResource DangerButton}"
                                                        ToolTip="{DynamicResource Tip.DelAllowedEmote}"/>
                                            </StackPanel>
                                        </StackPanel>
                                    </GroupBox>

                                    <GroupBox Header="{StaticResource Section.TtsCommands}" Margin="0,0,0,12">
                                        <StackPanel>
                                            <ListBox ItemsSource="{Binding SpeakingOptions.TtsCommands}"
                                                     SelectedItem="{Binding SpeakingOptions.SelectedTtsCommand}"
                                                     Height="80" BorderThickness="0" Background="{DynamicResource Bg3}">
                                                <ListBox.ItemTemplate>
                                                    <DataTemplate><TextBlock Text="{Binding}" FontSize="12"/></DataTemplate>
                                                </ListBox.ItemTemplate>
                                            </ListBox>
                                            <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                                <TextBox Text="{Binding SpeakingOptions.NewTtsCommand}" Width="120" Margin="0,0,6,0"/>
                                                <Button Content="{DynamicResource Btn.Add}" Command="{Binding SpeakingOptions.AddTtsCommandCommand}"
                                                        Margin="0,0,4,0" ToolTip="{DynamicResource Tip.AddTtsCommand}"/>
                                                <Button Content="{DynamicResource Btn.Del}" Command="{Binding SpeakingOptions.DeleteTtsCommandCommand}"
                                                        Style="{DynamicResource DangerButton}"
                                                        ToolTip="{DynamicResource Tip.DelTtsCommand}"/>
                                            </StackPanel>
                                        </StackPanel>
                                    </GroupBox>

                                    <GroupBox Header="{StaticResource Section.IgnoredPrefixes}">
                                        <StackPanel>
                                            <CheckBox Content="{DynamicResource Chk.IgnorePrefixedWith}" Margin="0,0,0,6"/>
                                            <ListBox ItemsSource="{Binding SpeakingOptions.IgnoredPrefixes}"
                                                     SelectedItem="{Binding SpeakingOptions.SelectedIgnoredPrefix}"
                                                     Height="80" BorderThickness="0" Background="{DynamicResource Bg3}">
                                                <ListBox.ItemTemplate>
                                                    <DataTemplate><TextBlock Text="{Binding}" FontSize="12"/></DataTemplate>
                                                </ListBox.ItemTemplate>
                                            </ListBox>
                                            <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                                <TextBox Text="{Binding SpeakingOptions.NewIgnoredPrefix}" Width="80" Margin="0,0,6,0"/>
                                                <Button Content="{DynamicResource Btn.Add}" Command="{Binding SpeakingOptions.AddIgnoredPrefixCommand}"
                                                        Margin="0,0,4,0" ToolTip="{DynamicResource Tip.AddIgnoredPrefix}"/>
                                                <Button Content="{DynamicResource Btn.Del}" Command="{Binding SpeakingOptions.DeleteIgnoredPrefixCommand}"
                                                        Style="{DynamicResource DangerButton}"
                                                        ToolTip="{DynamicResource Tip.DelIgnoredPrefix}"/>
                                            </StackPanel>
                                        </StackPanel>
                                    </GroupBox>
                                </StackPanel>
                            </Grid>
                        </ScrollViewer>
                    </TabItem>

                    <!-- ─── Filters ─── -->
                    <TabItem Header="{DynamicResource Tab.Filters}">
                        <DockPanel Margin="12">
                            <Button DockPanel.Dock="Top" Content="Import wordlist..." Command="{Binding Replacement.ImportWordlistCommand}"
                                    HorizontalAlignment="Left" Margin="0,0,0,8"/>

                            <Border DockPanel.Dock="Bottom" Background="{DynamicResource Bg2}"
                                    BorderBrush="{DynamicResource BorderBrush0}" BorderThickness="1"
                                    CornerRadius="5" Padding="10" Margin="0,8,0,0">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="70"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="6"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="6"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="6"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="8"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="8"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <TextBlock Grid.Row="0" Grid.Column="0" Text="{DynamicResource Lbl.Mode}" Style="{DynamicResource MutedText}" VerticalAlignment="Center"/>
                                    <ComboBox Grid.Row="0" Grid.Column="1" ItemsSource="{Binding Replacement.AvailableModes}"
                                              SelectedItem="{Binding Replacement.EditMode}"
                                              ToolTip="{DynamicResource Tip.FilterMode}"/>

                                    <TextBlock Grid.Row="2" Grid.Column="0" Text="{DynamicResource Lbl.Match}" Style="{DynamicResource MutedText}" VerticalAlignment="Center"/>
                                    <TextBox Grid.Row="2" Grid.Column="1" Text="{Binding Replacement.EditPattern}" ToolTip="{DynamicResource Tip.FilterMatch}">
                                        <TextBox.Style>
                                            <Style TargetType="TextBox" BasedOn="{StaticResource {x:Type TextBox}}">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Replacement.EditPatternMixed}" Value="True">
                                                        <Setter Property="Tag" Value="[multiple selected]"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBox.Style>
                                    </TextBox>

                                    <TextBlock Grid.Row="4" Grid.Column="0" Text="{DynamicResource Lbl.With}" Style="{DynamicResource MutedText}" VerticalAlignment="Center"
                                               Visibility="{Binding Replacement.IsReplaceMode, Converter={StaticResource BoolToVisibilityConverter}}"/>
                                    <TextBox Grid.Row="4" Grid.Column="1" Text="{Binding Replacement.EditReplacement}" ToolTip="{DynamicResource Tip.FilterWith}"
                                             Visibility="{Binding Replacement.IsReplaceMode, Converter={StaticResource BoolToVisibilityConverter}}">
                                        <TextBox.Style>
                                            <Style TargetType="TextBox" BasedOn="{StaticResource {x:Type TextBox}}">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Replacement.EditReplacementMixed}" Value="True">
                                                        <Setter Property="Tag" Value="[multiple selected]"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBox.Style>
                                    </TextBox>

                                    <StackPanel Grid.Row="6" Grid.Column="0" Grid.ColumnSpan="2" Orientation="Horizontal">
                                        <CheckBox Content="{DynamicResource Chk.Enabled}" IsChecked="{Binding Replacement.EditEnabled}"
                                                  IsThreeState="True" Margin="0,0,12,0" ToolTip="{DynamicResource Tip.FilterEnabled}"/>
                                        <CheckBox Content="{DynamicResource Chk.Regex}" IsChecked="{Binding Replacement.EditIsRegex}"
                                                  IsThreeState="True" Margin="0,0,12,0" ToolTip="{DynamicResource Tip.FilterRegex}"/>
                                        <CheckBox Content="Whole word" IsChecked="{Binding Replacement.EditWholeWord}"
                                                  IsThreeState="True"
                                                  Visibility="{Binding Replacement.WholeWordVisible, Converter={StaticResource BoolToVisibilityConverter}}"/>
                                    </StackPanel>

                                    <StackPanel Grid.Row="8" Grid.Column="0" Grid.ColumnSpan="2" Orientation="Horizontal" HorizontalAlignment="Right">
                                        <Button Content="{DynamicResource Btn.Add}" Command="{Binding Replacement.AddReplacementCommand}"
                                                Margin="0,0,4,0" ToolTip="{DynamicResource Tip.AddFilter}"/>
                                        <Button Content="{DynamicResource Btn.Delete}" Command="{Binding Replacement.DeleteReplacementCommand}"
                                                Style="{DynamicResource DangerButton}" Margin="0,0,4,0"
                                                ToolTip="{DynamicResource Tip.DeleteFilter}"/>
                                        <Button Content="{DynamicResource Btn.Save}" Command="{Binding Replacement.SaveReplacementCommand}"
                                                Style="{DynamicResource AccentButton}"
                                                ToolTip="{DynamicResource Tip.SaveFilter}"/>
                                    </StackPanel>

                                    <TextBlock Grid.Row="10" Grid.Column="0" Text="{DynamicResource Lbl.Sample}" Style="{DynamicResource MutedText}" VerticalAlignment="Center"/>
                                    <StackPanel Grid.Row="10" Grid.Column="1">
                                        <TextBox Text="{Binding Replacement.SampleInput, UpdateSourceTrigger=PropertyChanged}"
                                                 Margin="0,0,0,4" ToolTip="{DynamicResource Tip.FilterSampleInput}"/>
                                        <TextBox Text="{Binding Replacement.SampleOutput, Mode=OneWay}" IsReadOnly="True"
                                                 Background="{DynamicResource Bg3}" Foreground="{DynamicResource TextMuted}"
                                                 ToolTip="{DynamicResource Tip.FilterSampleOutput}"/>
                                    </StackPanel>
                                </Grid>
                            </Border>

                            <DataGrid ItemsSource="{Binding Replacement.Replacements}"
                                      SelectedItem="{Binding Replacement.SelectedReplacement}"
                                      SelectionMode="Extended"
                                      SelectionChanged="FiltersDataGrid_SelectionChanged"
                                      PreviewMouseLeftButtonDown="FiltersDataGrid_PreviewMouseLeftButtonDown">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Binding="{Binding Mode}" Width="Auto">
                                        <DataGridTextColumn.Header><TextBlock Text="{DynamicResource Col.Mode}"/></DataGridTextColumn.Header>
                                    </DataGridTextColumn>
                                    <DataGridCheckBoxColumn Binding="{Binding IsRegex}" Width="Auto">
                                        <DataGridCheckBoxColumn.Header><TextBlock Text="{DynamicResource Col.Regex}"/></DataGridCheckBoxColumn.Header>
                                        <DataGridCheckBoxColumn.ElementStyle>
                                            <Style TargetType="CheckBox" BasedOn="{StaticResource {x:Type CheckBox}}"/>
                                        </DataGridCheckBoxColumn.ElementStyle>
                                        <DataGridCheckBoxColumn.EditingElementStyle>
                                            <Style TargetType="CheckBox" BasedOn="{StaticResource {x:Type CheckBox}}"/>
                                        </DataGridCheckBoxColumn.EditingElementStyle>
                                    </DataGridCheckBoxColumn>
                                    <DataGridCheckBoxColumn Header="Word" Binding="{Binding WholeWord}" Width="Auto">
                                        <DataGridCheckBoxColumn.ElementStyle>
                                            <Style TargetType="CheckBox" BasedOn="{StaticResource {x:Type CheckBox}}"/>
                                        </DataGridCheckBoxColumn.ElementStyle>
                                        <DataGridCheckBoxColumn.EditingElementStyle>
                                            <Style TargetType="CheckBox" BasedOn="{StaticResource {x:Type CheckBox}}"/>
                                        </DataGridCheckBoxColumn.EditingElementStyle>
                                    </DataGridCheckBoxColumn>
                                    <DataGridCheckBoxColumn Binding="{Binding Enabled}" Width="Auto">
                                        <DataGridCheckBoxColumn.Header><TextBlock Text="{DynamicResource Col.On}"/></DataGridCheckBoxColumn.Header>
                                        <DataGridCheckBoxColumn.ElementStyle>
                                            <Style TargetType="CheckBox" BasedOn="{StaticResource {x:Type CheckBox}}"/>
                                        </DataGridCheckBoxColumn.ElementStyle>
                                        <DataGridCheckBoxColumn.EditingElementStyle>
                                            <Style TargetType="CheckBox" BasedOn="{StaticResource {x:Type CheckBox}}"/>
                                        </DataGridCheckBoxColumn.EditingElementStyle>
                                    </DataGridCheckBoxColumn>
                                    <DataGridTextColumn Binding="{Binding Pattern}" Width="*">
                                        <DataGridTextColumn.Header><TextBlock Text="{DynamicResource Col.Pattern}"/></DataGridTextColumn.Header>
                                    </DataGridTextColumn>
                                    <DataGridTextColumn Binding="{Binding Replacement}" Width="*">
                                        <DataGridTextColumn.Header><TextBlock Text="{DynamicResource Col.ReplaceWith}"/></DataGridTextColumn.Header>
                                    </DataGridTextColumn>
                                </DataGrid.Columns>
                            </DataGrid>
                        </DockPanel>
                    </TabItem>

                    <!-- ─── Voice Aliases ─── -->
                    <TabItem Header="{DynamicResource Tab.VoiceAliases}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="180"/>
                                <ColumnDefinition Width="1"/>
                                <ColumnDefinition Width="220"/>
                                <ColumnDefinition Width="1"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <Grid Grid.Column="0">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                <TextBox Grid.Row="0"
                                         Margin="8,8,8,4"
                                         Tag="Search aliases..."
                                         Text="{Binding VoiceAliases.AliasFilter, UpdateSourceTrigger=PropertyChanged}"/>
                                <ListBox Grid.Row="1"
                                         ItemsSource="{Binding VoiceAliases.Aliases}"
                                         SelectedItem="{Binding VoiceAliases.SelectedAlias}"
                                         BorderThickness="0" Background="Transparent" Padding="4">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding Name}" Padding="4,2"/>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                            </Grid>

                            <Border Grid.Column="1" Background="{DynamicResource BorderBrush0}"/>

                            <DockPanel Grid.Column="2" VerticalAlignment="Stretch">
                                <StackPanel DockPanel.Dock="Top" Margin="4,4,4,2">
                                    <ComboBox ItemsSource="{Binding VoiceAliases.FilteredUsers}"
                                              SelectedItem="{Binding VoiceAliases.SelectedUserToAdd}"
                                              Tag="{Binding VoiceAliases.UserFilter, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                              ScrollViewer.CanContentScroll="True"
                                              MaxDropDownHeight="250"
                                              DisplayMemberPath="Username">
                                        <ComboBox.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <VirtualizingStackPanel/>
                                            </ItemsPanelTemplate>
                                        </ComboBox.ItemsPanel>
                                    </ComboBox>
                                    <Button Content="{DynamicResource Btn.Add}"
                                            Command="{Binding VoiceAliases.AddUserToAliasCommand}"
                                            Margin="0,4,0,0" HorizontalAlignment="Stretch"/>
                                </StackPanel>
                                <Border DockPanel.Dock="Top" Height="1" Background="{DynamicResource BorderBrush0}" Margin="4,4,4,0"/>
                                <ListBox ItemsSource="{Binding VoiceAliases.InUseUsers}"
                                         BorderThickness="0" Background="Transparent">
                                    <ListBox.ItemContainerStyle>
                                        <Style TargetType="ListBoxItem">
                                            <Setter Property="Tag" Value="{Binding DataContext.VoiceAliases.RemoveUserFromAliasCommand, RelativeSource={RelativeSource AncestorType=ListBox}}"/>
                                            <Setter Property="ContextMenu">
                                                <Setter.Value>
                                                    <ContextMenu>
                                                        <MenuItem Header="Remove from alias"
                                                                  Command="{Binding PlacementTarget.Tag, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                                  CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                                                    </ContextMenu>
                                                </Setter.Value>
                                            </Setter>
                                        </Style>
                                    </ListBox.ItemContainerStyle>
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding}"/>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                            </DockPanel>

                            <Border Grid.Column="3" Background="{DynamicResource BorderBrush0}"/>

                            <DockPanel Grid.Column="4">

                                <DockPanel DockPanel.Dock="Top" Margin="6,6,6,4">
                                    <Button DockPanel.Dock="Right" Content="{DynamicResource Btn.Add}"
                                            Command="{Binding VoiceAliases.AddAliasCommand}"
                                            Margin="4,0,0,0" VerticalAlignment="Center"
                                            ToolTip="{DynamicResource Tip.AddVoiceAlias}"/>
                                    <Button DockPanel.Dock="Right" Content="{DynamicResource Btn.Rename}"
                                            Command="{Binding VoiceAliases.RenameCommand}"
                                            Margin="4,0,0,0" VerticalAlignment="Center"
                                            ToolTip="{DynamicResource Tip.RenameVoiceAlias}"/>
                                    <TextBlock DockPanel.Dock="Left" Text="{DynamicResource Lbl.Name}" VerticalAlignment="Center"
                                               Margin="0,0,8,0" Width="40"/>
                                    <TextBox Text="{Binding VoiceAliases.DetailName, UpdateSourceTrigger=PropertyChanged}"
                                             VerticalAlignment="Center"/>
                                </DockPanel>

                                <DockPanel IsEnabled="{Binding VoiceAliases.HasSelected}">

                                    <StackPanel DockPanel.Dock="Bottom" Margin="6,4,6,6">
                                        <DockPanel Margin="0,0,0,4">
                                            <TextBlock DockPanel.Dock="Left" Text="{DynamicResource Lbl.Voice}" VerticalAlignment="Center" Width="42"/>
                                            <ComboBox x:Name="AliasVoiceComboBox"
                                                      SelectedItem="{Binding VoiceAliases.TestSpeakVoice}"
                                                      ItemsSource="{Binding VoiceAliases.SpeakVoices}"
                                                      Tag="{Binding VoiceAliases.VoiceFilter, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                      ToolTip="{DynamicResource Tip.VoiceAliasTestVoice}"
                                                      ScrollViewer.CanContentScroll="True"
                                                      MaxDropDownHeight="300">
                                                <ComboBox.ItemsPanel>
                                                    <ItemsPanelTemplate>
                                                        <VirtualizingStackPanel IsVirtualizing="True" VirtualizationMode="Recycling"/>
                                                    </ItemsPanelTemplate>
                                                </ComboBox.ItemsPanel>
                                            </ComboBox>
                                        </DockPanel>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="4"/>
                                                <RowDefinition Height="Auto"/>
                                            </Grid.RowDefinitions>

                                            <DockPanel Grid.Row="0" Grid.Column="0">
                                                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" Margin="8,0,0,0" VerticalAlignment="Center">
                                                    <TextBlock Text="{DynamicResource Lbl.Volume}" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                                    <controls:NumericSlider Minimum="0" Maximum="100" Value="{Binding VoiceAliases.TestVolume}"
                                                            SliderWidth="80" Suffix="%"
                                                            ToolTip="{DynamicResource Tip.VoiceAliasVolume}"/>
                                                </StackPanel>
                                                <TextBox Text="{Binding VoiceAliases.TestMessage}"
                                                         ToolTip="{DynamicResource Tip.VoiceAliasTestMessage}"/>
                                            </DockPanel>
                                            <StackPanel Grid.Row="0" Grid.Column="1" Orientation="Horizontal" Margin="6,0,0,0">
                                                <Button Content="{DynamicResource Btn.SetDefault}" Command="{Binding VoiceAliases.SetDefaultVoiceCommand}"
                                                        Margin="0,0,3,0" ToolTip="{DynamicResource Tip.SetDefaultVoice}"/>
                                                <Button Content="{DynamicResource Btn.Add}" Command="{Binding VoiceAliases.AddVoiceCommand}"
                                                        ToolTip="{DynamicResource Tip.AddVoiceToAlias}"/>
                                            </StackPanel>

                                            <ItemsControl Grid.Row="2" Grid.Column="0"
                                                          ItemsSource="{Binding VoiceAliases.ParamRows}"
                                                          VerticalAlignment="Center">
                                                <ItemsControl.ItemsPanel>
                                                    <ItemsPanelTemplate>
                                                        <WrapPanel Orientation="Horizontal"/>
                                                    </ItemsPanelTemplate>
                                                </ItemsControl.ItemsPanel>
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <StackPanel Orientation="Horizontal" Margin="0,0,10,0" VerticalAlignment="Center">
                                                            <TextBlock Text="{Binding Def.Label}" Style="{DynamicResource MutedText}"
                                                                       VerticalAlignment="Center" Margin="0,0,5,0"/>
                                                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center"
                                                                        Visibility="{Binding IsSlider, Converter={StaticResource BoolToVisibilityConverter}}">
                                                                <controls:NumericSlider Value="{Binding SliderValue, Mode=TwoWay}"
                                                                        Minimum="{Binding Def.Min}" Maximum="{Binding Def.Max}"
                                                                        SmallChange="{Binding Def.Step}" LargeChange="{Binding Def.Step}"
                                                                        SliderWidth="70"/>
                                                            </StackPanel>
                                                            <ComboBox ItemsSource="{Binding Def.Options}" SelectedItem="{Binding Value}"
                                                                      Width="150" VerticalAlignment="Center"
                                                                      Visibility="{Binding IsComboBox, Converter={StaticResource BoolToVisibilityConverter}}"/>
                                                            <ComboBox Width="240" VerticalAlignment="Center" MaxDropDownHeight="300"
                                                                      ItemsSource="{Binding VoiceOptions}" SelectedItem="{Binding SelectedVoiceOption}"
                                                                      Tag="{Binding SearchText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                                      Visibility="{Binding IsSearchableVoice, Converter={StaticResource BoolToVisibilityConverter}}">
                                                                <ComboBox.ItemsPanel>
                                                                    <ItemsPanelTemplate><VirtualizingStackPanel IsVirtualizing="True" VirtualizationMode="Recycling"/></ItemsPanelTemplate>
                                                                </ComboBox.ItemsPanel>
                                                                <ComboBox.ItemTemplate>
                                                                    <DataTemplate>
                                                                        <StackPanel Orientation="Horizontal" FlowDirection="LeftToRight">
                                                                            <TextBlock Text="{Binding Name}" TextTrimming="CharacterEllipsis"/>
                                                                            <TextBlock Text="  ·  by " Opacity="0.6"/>
                                                                            <TextBlock Text="{Binding Author}" Opacity="0.6" FlowDirection="LeftToRight"/>
                                                                            <TextBlock Text="   ♥ " Opacity="0.6"/>
                                                                            <TextBlock Text="{Binding LikeCount}" Opacity="0.6"/>
                                                                        </StackPanel>
                                                                    </DataTemplate>
                                                                </ComboBox.ItemTemplate>
                                                            </ComboBox>
                                                        </StackPanel>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                            <Button Grid.Row="2" Grid.Column="1" Content="{DynamicResource Btn.TestSpeak}"
                                                    Command="{Binding VoiceAliases.TestSpeakCommand}"
                                                    HorizontalAlignment="Stretch" Margin="6,0,0,0"
                                                    ToolTip="{DynamicResource Tip.TestSpeak}"/>
                                        </Grid>
                                    </StackPanel>

                                    <DockPanel Margin="6,4,6,0">
                                        <DockPanel DockPanel.Dock="Top" Margin="0,0,0,4">
                                            <TextBlock DockPanel.Dock="Left" Text="{DynamicResource Lbl.OutputDevice}"
                                                       VerticalAlignment="Center" Width="90"/>
                                            <ComboBox SelectedValue="{Binding VoiceAliases.DetailOutputDeviceId}"
                                                      SelectedValuePath="Id"
                                                      ItemsSource="{Binding VoiceAliases.OutputDevices}"
                                                      ToolTip="{DynamicResource Tip.VoiceAliasOutputDevice}">
                                                <ComboBox.ItemTemplate>
                                                    <DataTemplate>
                                                        <TextBlock Text="{Binding Name}"/>
                                                    </DataTemplate>
                                                </ComboBox.ItemTemplate>
                                            </ComboBox>
                                        </DockPanel>
                                        <DataGrid ItemsSource="{Binding VoiceAliases.AliasVoices}"
                                                  SelectedItem="{Binding VoiceAliases.SelectedVoice}"
                                                  AutoGenerateColumns="False" CanUserAddRows="False" IsReadOnly="True"
                                                  BorderThickness="1" BorderBrush="{DynamicResource BorderBrush0}"
                                                  PreviewMouseLeftButtonDown="AliasVoicesDataGrid_PreviewMouseLeftButtonDown">
                                            <DataGrid.ContextMenu>
                                                <ContextMenu DataContext="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource Self}}">
                                                    <MenuItem Header="{DynamicResource Btn.Remove}" Command="{Binding VoiceAliases.RemoveVoiceCommand}"/>
                                                    <MenuItem Header="{DynamicResource Btn.RemoveAll}" Command="{Binding VoiceAliases.RemoveAllVoicesCommand}"/>
                                                </ContextMenu>
                                            </DataGrid.ContextMenu>
                                            <DataGrid.Columns>
                                                <DataGridTextColumn Binding="{Binding Name}" Width="*">
                                                    <DataGridTextColumn.Header><TextBlock Text="{DynamicResource Col.Name}"/></DataGridTextColumn.Header>
                                                </DataGridTextColumn>
                                            </DataGrid.Columns>
                                        </DataGrid>
                                    </DockPanel>

                                </DockPanel>
                            </DockPanel>
                        </Grid>
                    </TabItem>

                    <!-- ─── WebSocket Server ─── -->
                    <TabItem Header="{DynamicResource Tab.WebSocket}">
                        <StackPanel Margin="16" MaxWidth="400" HorizontalAlignment="Left">
                            <GroupBox Header="{StaticResource Section.Settings}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="90"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="6"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="6"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="6"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <CheckBox Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="2"
                                              Content="{DynamicResource Chk.AutoStart}" IsChecked="{Binding WebSocketServer.AutoStart}"
                                              ToolTip="{DynamicResource Tip.WsAutoStart}"/>
                                    <TextBlock Grid.Row="2" Grid.Column="0" Text="{DynamicResource Lbl.Address}" Style="{DynamicResource MutedText}" VerticalAlignment="Center"/>
                                    <TextBox Grid.Row="2" Grid.Column="1" Text="{Binding WebSocketServer.Address}"
                                             ToolTip="{DynamicResource Tip.WsAddress}"/>
                                    <TextBlock Grid.Row="4" Grid.Column="0" Text="{DynamicResource Lbl.Port}" Style="{DynamicResource MutedText}" VerticalAlignment="Center"/>
                                    <TextBox Grid.Row="4" Grid.Column="1" Text="{Binding WebSocketServer.Port}"
                                             ToolTip="{DynamicResource Tip.WsPort}"/>
                                    <TextBlock Grid.Row="6" Grid.Column="0" Text="{DynamicResource Lbl.Endpoint}" Style="{DynamicResource MutedText}" VerticalAlignment="Center"/>
                                    <TextBox Grid.Row="6" Grid.Column="1" Text="{Binding WebSocketServer.Endpoint}"
                                             ToolTip="{DynamicResource Tip.WsEndpoint}"/>
                                </Grid>
                            </GroupBox>
                            <StackPanel Orientation="Horizontal" Margin="0,12,0,0">
                                <Button Content="{DynamicResource Btn.StartServer}" Command="{Binding WebSocketServer.StartCommand}"
                                        Style="{DynamicResource AccentButton}" Margin="0,0,8,0"
                                        ToolTip="{DynamicResource Tip.StartWsServer}"/>
                                <Button Content="{DynamicResource Btn.StopServer}" Command="{Binding WebSocketServer.StopCommand}"
                                        Margin="0,0,8,0" ToolTip="{DynamicResource Tip.StopWsServer}"/>
                            </StackPanel>
                            <GroupBox Header="UDP Server" Margin="0,16,0,0">
                                <StackPanel>
                                    <CheckBox Content="{DynamicResource Chk.AutoStart}" IsChecked="{Binding UdpServer.AutoStart}" Margin="0,0,0,4"/>
                                    <TextBlock Style="{DynamicResource MutedText}" Text="Port 6669 (fixed)" Margin="0,0,0,8"/>
                                    <StackPanel Orientation="Horizontal">
                                        <Button Content="{DynamicResource Btn.StartServer}" Command="{Binding UdpServer.StartCommand}"
                                                Style="{DynamicResource AccentButton}" Margin="0,0,8,0"/>
                                        <Button Content="{DynamicResource Btn.StopServer}" Command="{Binding UdpServer.StopCommand}"
                                                Margin="0,0,8,0"/>
                                    </StackPanel>
                                </StackPanel>
                            </GroupBox>
                        </StackPanel>
                    </TabItem>

                    <!-- ─── Custom APIs ─── -->
                    <TabItem Header="{DynamicResource Tab.CustomApis}">
                        <Grid Margin="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="220"/>
                                <ColumnDefinition Width="12"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <DockPanel Grid.Column="0">
                                <TextBlock DockPanel.Dock="Top" Text="{DynamicResource Section.CustomApiServers}" Style="{DynamicResource SectionLabel}" Margin="0,0,0,6"/>
                                <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" Margin="0,8,0,0">
                                    <Button Content="{DynamicResource Btn.Add}" Command="{Binding CustomApis.AddCommand}"
                                            Style="{DynamicResource AccentButton}" Margin="0,0,4,0"
                                            ToolTip="{DynamicResource Tip.AddCustomApi}"/>
                                    <Button Content="{DynamicResource Btn.Delete}" Command="{Binding CustomApis.DeleteCommand}"
                                            Style="{DynamicResource DangerButton}"
                                            ToolTip="{DynamicResource Tip.DeleteCustomApi}"/>
                                </StackPanel>
                                <ListBox ItemsSource="{Binding CustomApis.Definitions}"
                                         SelectedItem="{Binding CustomApis.Selected}"
                                         BorderThickness="0" Background="{DynamicResource Bg2}">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <StackPanel Margin="2">
                                                <TextBlock Text="{Binding Name}" FontWeight="SemiBold"/>
                                                <TextBlock Text="{Binding SynthUrl}"
                                                           FontSize="11" FontFamily="Consolas"
                                                           TextTrimming="CharacterEllipsis">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock" BasedOn="{StaticResource MutedText}">
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding SynthUrl}" Value="">
                                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                            </StackPanel>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                            </DockPanel>

                            <ScrollViewer Grid.Column="2" VerticalScrollBarVisibility="Auto">
                                <ScrollViewer.Style>
                                    <Style TargetType="ScrollViewer">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding CustomApis.HasSelected}" Value="False">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </ScrollViewer.Style>
                                <StackPanel Margin="0,0,8,0">

                                    <Grid Margin="0,0,0,16">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="16"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0">
                                            <TextBlock Text="{DynamicResource Section.Name}" Style="{DynamicResource SectionLabel}" Margin="0,0,0,4"/>
                                            <TextBox Text="{Binding CustomApis.Edit.Name, UpdateSourceTrigger=PropertyChanged}"/>
                                        </StackPanel>
                                        <StackPanel Grid.Column="2" VerticalAlignment="Bottom">
                                            <CheckBox Content="{DynamicResource Chk.Enabled}" IsChecked="{Binding CustomApis.Edit.Enabled}"
                                                      ToolTip="{DynamicResource Tip.CustomApiEnabled}"/>
                                        </StackPanel>
                                    </Grid>

                                    <Border Background="{DynamicResource Bg2}" BorderBrush="{DynamicResource BorderBrush0}"
                                            BorderThickness="1" CornerRadius="4" Padding="14,10" Margin="0,0,0,10">
                                        <StackPanel>
                                            <TextBlock Text="{DynamicResource Section.Synthesis}" Style="{DynamicResource SectionLabel}" Margin="0,0,0,10"/>

                                            <Grid Margin="0,0,0,8">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="8"/>
                                                    <ColumnDefinition Width="90"/>
                                                </Grid.ColumnDefinitions>
                                                <StackPanel Grid.Column="0">
                                                    <TextBlock Text="{DynamicResource Lbl.Url}" Style="{DynamicResource MutedText}" Margin="0,0,0,3"/>
                                                    <TextBox Text="{Binding CustomApis.Edit.SynthUrl, UpdateSourceTrigger=PropertyChanged}"
                                                             FontFamily="Consolas" FontSize="12"
                                                             ToolTip="{DynamicResource Tip.SynthUrl}"/>
                                                </StackPanel>
                                                <StackPanel Grid.Column="2">
                                                    <TextBlock Text="{DynamicResource Lbl.Method}" Style="{DynamicResource MutedText}" Margin="0,0,0,3"/>
                                                    <ComboBox ItemsSource="{Binding CustomApis.Edit.Methods}" SelectedItem="{Binding CustomApis.Edit.SynthMethod}"
                                                              ToolTip="{DynamicResource Tip.SynthMethod}">
                                                        <ComboBox.ItemTemplate><DataTemplate><TextBlock Text="{Binding}"/></DataTemplate></ComboBox.ItemTemplate>
                                                    </ComboBox>
                                                </StackPanel>
                                            </Grid>

                                            <TextBlock Text="{DynamicResource Lbl.BodyTemplate}" Style="{DynamicResource MutedText}" Margin="0,0,0,3"/>
                                            <TextBox Text="{Binding CustomApis.Edit.SynthBodyTemplate, UpdateSourceTrigger=PropertyChanged}"
                                                     FontFamily="Consolas" FontSize="12" AcceptsReturn="True"
                                                     TextWrapping="Wrap" MinHeight="60" Margin="0,0,0,8"
                                                     ToolTip="{DynamicResource Tip.SynthBody}"/>

                                            <Grid Margin="0,0,0,8">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="8"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="8"/>
                                                    <ColumnDefinition Width="90"/>
                                                </Grid.ColumnDefinitions>
                                                <StackPanel Grid.Column="0">
                                                    <TextBlock Text="{DynamicResource Lbl.ResponseFormat}" Style="{DynamicResource MutedText}" Margin="0,0,0,3"/>
                                                    <ComboBox ItemsSource="{Binding CustomApis.Edit.ResponseFormats}" SelectedItem="{Binding CustomApis.Edit.ResponseFormat}"
                                                              ToolTip="{DynamicResource Tip.ResponseFormat}">
                                                        <ComboBox.ItemTemplate><DataTemplate><TextBlock Text="{Binding}"/></DataTemplate></ComboBox.ItemTemplate>
                                                    </ComboBox>
                                                </StackPanel>
                                                <StackPanel Grid.Column="2"
                                                            Visibility="{Binding CustomApis.Edit.IsJsonResponse, Converter={StaticResource BoolToVisibilityConverter}}">
                                                    <TextBlock Text="{DynamicResource Lbl.JsonPath}" Style="{DynamicResource MutedText}" Margin="0,0,0,3"/>
                                                    <TextBox Text="{Binding CustomApis.Edit.ResponseAudioPath, UpdateSourceTrigger=PropertyChanged}"
                                                             FontFamily="Consolas" FontSize="12"
                                                             ToolTip="{DynamicResource Tip.JsonAudioPath}"/>
                                                </StackPanel>
                                                <StackPanel Grid.Column="4">
                                                    <TextBlock Text="{DynamicResource Lbl.AudioFormat}" Style="{DynamicResource MutedText}" Margin="0,0,0,3"/>
                                                    <ComboBox ItemsSource="{Binding CustomApis.Edit.AudioFormats}" SelectedItem="{Binding CustomApis.Edit.AudioFormat}"
                                                              ToolTip="{DynamicResource Tip.AudioFormat}">
                                                        <ComboBox.ItemTemplate><DataTemplate><TextBlock Text="{Binding}"/></DataTemplate></ComboBox.ItemTemplate>
                                                    </ComboBox>
                                                </StackPanel>
                                            </Grid>

                                            <TextBlock Text="{DynamicResource Section.Headers}" Style="{DynamicResource SectionLabel}" Margin="0,4,0,6"/>
                                            <ItemsControl ItemsSource="{Binding CustomApis.Edit.SynthHeaders}" Margin="0,0,0,6">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <Grid Margin="0,0,0,4">
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="*"/>
                                                                <ColumnDefinition Width="8"/>
                                                                <ColumnDefinition Width="*"/>
                                                                <ColumnDefinition Width="6"/>
                                                                <ColumnDefinition Width="28"/>
                                                            </Grid.ColumnDefinitions>
                                                            <TextBox Grid.Column="0" Text="{Binding Key, UpdateSourceTrigger=PropertyChanged}" FontFamily="Consolas" FontSize="12"/>
                                                            <TextBox Grid.Column="2" Text="{Binding Value, UpdateSourceTrigger=PropertyChanged}" FontFamily="Consolas" FontSize="12"/>
                                                            <Button Grid.Column="4" Content="×" Padding="0"
                                                                    Command="{Binding DataContext.CustomApis.Edit.RemoveSynthHeaderCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                    CommandParameter="{Binding}"/>
                                                        </Grid>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                            <Button Content="{DynamicResource Btn.AddHeader}" HorizontalAlignment="Left" Padding="10,4"
                                                    Command="{Binding CustomApis.Edit.AddSynthHeaderCommand}"
                                                    ToolTip="{DynamicResource Tip.AddSynthHeader}"/>
                                        </StackPanel>
                                    </Border>

                                    <Border Background="{DynamicResource Bg2}" BorderBrush="{DynamicResource BorderBrush0}"
                                            BorderThickness="1" CornerRadius="4" Padding="14,10" Margin="0,0,0,10">
                                        <StackPanel>
                                            <TextBlock Text="{DynamicResource Section.Voices}" Style="{DynamicResource SectionLabel}" Margin="0,0,0,10"/>

                                            <Grid Margin="0,0,0,8">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="8"/>
                                                    <ColumnDefinition Width="90"/>
                                                </Grid.ColumnDefinitions>
                                                <StackPanel Grid.Column="0">
                                                    <TextBlock Text="{DynamicResource Lbl.Url}" Style="{DynamicResource MutedText}" Margin="0,0,0,3"/>
                                                    <TextBox Text="{Binding CustomApis.Edit.VoicesUrl, UpdateSourceTrigger=PropertyChanged}"
                                                             FontFamily="Consolas" FontSize="12"
                                                             ToolTip="{DynamicResource Tip.VoicesUrl}"/>
                                                </StackPanel>
                                                <StackPanel Grid.Column="2">
                                                    <TextBlock Text="{DynamicResource Lbl.Method}" Style="{DynamicResource MutedText}" Margin="0,0,0,3"/>
                                                    <ComboBox ItemsSource="{Binding CustomApis.Edit.Methods}" SelectedItem="{Binding CustomApis.Edit.VoicesMethod}"
                                                              ToolTip="{DynamicResource Tip.VoicesMethod}">
                                                        <ComboBox.ItemTemplate><DataTemplate><TextBlock Text="{Binding}"/></DataTemplate></ComboBox.ItemTemplate>
                                                    </ComboBox>
                                                </StackPanel>
                                            </Grid>

                                            <Grid Margin="0,0,0,8">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="8"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="8"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <StackPanel Grid.Column="0">
                                                    <TextBlock Text="{DynamicResource Lbl.ArrayPath}" Style="{DynamicResource MutedText}" Margin="0,0,0,3"/>
                                                    <TextBox Text="{Binding CustomApis.Edit.VoicesArrayPath, UpdateSourceTrigger=PropertyChanged}"
                                                             FontFamily="Consolas" FontSize="12"
                                                             ToolTip="{DynamicResource Tip.VoicesArrayPath}"/>
                                                </StackPanel>
                                                <StackPanel Grid.Column="2">
                                                    <TextBlock Text="{DynamicResource Lbl.VoiceIdPath}" Style="{DynamicResource MutedText}" Margin="0,0,0,3"/>
                                                    <TextBox Text="{Binding CustomApis.Edit.VoiceIdField, UpdateSourceTrigger=PropertyChanged}"
                                                             FontFamily="Consolas" FontSize="12"
                                                             ToolTip="{DynamicResource Tip.VoiceIdFieldPath}"/>
                                                </StackPanel>
                                                <StackPanel Grid.Column="4">
                                                    <TextBlock Text="{DynamicResource Lbl.DisplayNamePath}" Style="{DynamicResource MutedText}" Margin="0,0,0,3"/>
                                                    <TextBox Text="{Binding CustomApis.Edit.VoiceNameField, UpdateSourceTrigger=PropertyChanged}"
                                                             FontFamily="Consolas" FontSize="12"
                                                             ToolTip="{DynamicResource Tip.VoiceNameFieldPath}"/>
                                                </StackPanel>
                                            </Grid>

                                            <TextBlock Text="{DynamicResource Section.Headers}" Style="{DynamicResource SectionLabel}" Margin="0,4,0,6"/>
                                            <ItemsControl ItemsSource="{Binding CustomApis.Edit.VoicesHeaders}" Margin="0,0,0,6">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <Grid Margin="0,0,0,4">
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="*"/>
                                                                <ColumnDefinition Width="8"/>
                                                                <ColumnDefinition Width="*"/>
                                                                <ColumnDefinition Width="6"/>
                                                                <ColumnDefinition Width="28"/>
                                                            </Grid.ColumnDefinitions>
                                                            <TextBox Grid.Column="0" Text="{Binding Key, UpdateSourceTrigger=PropertyChanged}" FontFamily="Consolas" FontSize="12"/>
                                                            <TextBox Grid.Column="2" Text="{Binding Value, UpdateSourceTrigger=PropertyChanged}" FontFamily="Consolas" FontSize="12"/>
                                                            <Button Grid.Column="4" Content="×" Padding="0"
                                                                    Command="{Binding DataContext.CustomApis.Edit.RemoveVoicesHeaderCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                    CommandParameter="{Binding}"/>
                                                        </Grid>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                            <Button Content="{DynamicResource Btn.AddHeader}" HorizontalAlignment="Left" Padding="10,4"
                                                    Command="{Binding CustomApis.Edit.AddVoicesHeaderCommand}"
                                                    ToolTip="{DynamicResource Tip.AddVoicesHeader}"/>
                                        </StackPanel>
                                    </Border>

                                    <Button Content="{DynamicResource Btn.SaveEngine}" HorizontalAlignment="Right" Padding="20,7"
                                            Style="{DynamicResource AccentButton}"
                                            Command="{Binding CustomApis.SaveCommand}"
                                            Margin="0,0,0,12"
                                            ToolTip="{DynamicResource Tip.SaveCustomApi}"/>

                                </StackPanel>
                            </ScrollViewer>
                        </Grid>
                    </TabItem>

                    <!-- ─── Extensions ─── -->
                    <TabItem Header="{DynamicResource Tab.Extensions}">
                        <Grid Margin="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="220"/>
                                <ColumnDefinition Width="12"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <DockPanel Grid.Column="0">
                                <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" Margin="0,8,0,0">
                                    <Button Content="Reload" Command="{Binding Extensions.ReloadCommand}"
                                            Style="{DynamicResource AccentButton}" Padding="10,4" Margin="0,0,4,0"/>
                                    <Button Content="Open Folder" Command="{Binding Extensions.OpenExtensionsFolderCommand}"
                                            Padding="10,4"/>
                                </StackPanel>
                                <ListBox ItemsSource="{Binding Extensions.Items}"
                                         SelectedItem="{Binding Extensions.Selected}"
                                         BorderThickness="0" Background="{DynamicResource Bg2}">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <StackPanel Margin="2">
                                                <TextBlock Text="{Binding DisplayName}" FontWeight="SemiBold"/>
                                                <TextBlock Text="{Binding Status}" FontSize="11"
                                                           Foreground="{DynamicResource TextMuted}"/>
                                            </StackPanel>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                            </DockPanel>

                            <ScrollViewer Grid.Column="2" VerticalScrollBarVisibility="Auto">
                                <StackPanel>
                                    <StackPanel.Style>
                                        <Style TargetType="StackPanel">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Extensions.Selected}" Value="{x:Null}">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </StackPanel.Style>

                                    <TextBlock Text="{Binding Extensions.Selected.DisplayName}"
                                               FontSize="16" FontWeight="SemiBold" Margin="0,0,0,4"/>
                                    <TextBlock Text="{Binding Extensions.Selected.EngineId}"
                                               FontFamily="Consolas" FontSize="11"
                                               Foreground="{DynamicResource TextMuted}" Margin="0,0,0,8"/>
                                    <TextBlock Text="{Binding Extensions.Selected.Description}"
                                               Foreground="{DynamicResource TextSecondary}" FontSize="12"
                                               TextWrapping="Wrap" Margin="0,0,0,12"/>

                                    <Button Content="Open Extension Folder"
                                            Command="{Binding Extensions.OpenFolderCommand}"
                                            HorizontalAlignment="Left" Padding="14,6" Margin="0,0,0,16"/>

                                    <ItemsControl ItemsSource="{Binding Extensions.Selected.InfoCards}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Background="{DynamicResource Bg2}" BorderBrush="{DynamicResource BorderBrush0}"
                                                        BorderThickness="1" CornerRadius="4" Padding="12" Margin="0,0,0,8">
                                                    <StackPanel>
                                                        <TextBlock Text="{Binding Header}" Style="{DynamicResource SectionLabel}" Margin="0,0,0,6"/>
                                                        <TextBlock Text="{Binding Body}" TextWrapping="Wrap"
                                                                   Foreground="{DynamicResource TextSecondary}" FontSize="12"/>
                                                    </StackPanel>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>

                                    <!-- Settings section -->
                                    <Border Background="{DynamicResource Bg2}" BorderBrush="{DynamicResource BorderBrush0}"
                                            BorderThickness="1" CornerRadius="4" Padding="12" Margin="0,8,0,0">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Extensions.HasSettings}" Value="False">
                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <StackPanel>
                                            <TextBlock Text="SETTINGS" Style="{DynamicResource SectionLabel}" Margin="0,0,0,10"/>

                                            <ItemsControl ItemsSource="{Binding Extensions.SettingFields}">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <Grid Margin="0,0,0,8">
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="140"/>
                                                                <ColumnDefinition Width="*"/>
                                                            </Grid.ColumnDefinitions>
                                                            <TextBlock Text="{Binding Label}" VerticalAlignment="Center"
                                                                       Foreground="{DynamicResource TextSecondary}" FontSize="12"/>

                                                            <TextBox Grid.Column="1"
                                                                     Text="{Binding Value, UpdateSourceTrigger=PropertyChanged}">
                                                                <TextBox.Style>
                                                                    <Style TargetType="TextBox" BasedOn="{StaticResource {x:Type TextBox}}">
                                                                        <Style.Triggers>
                                                                            <DataTrigger Binding="{Binding IsTextLike}" Value="False">
                                                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                                            </DataTrigger>
                                                                        </Style.Triggers>
                                                                    </Style>
                                                                </TextBox.Style>
                                                            </TextBox>

                                                            <CheckBox Grid.Column="1"
                                                                      IsChecked="{Binding BoolValue}"
                                                                      VerticalAlignment="Center">
                                                                <CheckBox.Style>
                                                                    <Style TargetType="CheckBox" BasedOn="{StaticResource {x:Type CheckBox}}">
                                                                        <Style.Triggers>
                                                                            <DataTrigger Binding="{Binding IsCheckbox}" Value="False">
                                                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                                            </DataTrigger>
                                                                        </Style.Triggers>
                                                                    </Style>
                                                                </CheckBox.Style>
                                                            </CheckBox>

                                                            <ComboBox Grid.Column="1"
                                                                      ItemsSource="{Binding Options}"
                                                                      SelectedItem="{Binding Value}">
                                                                <ComboBox.Style>
                                                                    <Style TargetType="ComboBox" BasedOn="{StaticResource {x:Type ComboBox}}">
                                                                        <Style.Triggers>
                                                                            <DataTrigger Binding="{Binding IsDropdown}" Value="False">
                                                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                                            </DataTrigger>
                                                                        </Style.Triggers>
                                                                    </Style>
                                                                </ComboBox.Style>
                                                            </ComboBox>
                                                        </Grid>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>

                                            <Button Content="Save Settings" Command="{Binding Extensions.SaveSettingsCommand}"
                                                    Style="{DynamicResource AccentButton}"
                                                    HorizontalAlignment="Left" Padding="14,6" Margin="0,8,0,0"/>
                                        </StackPanel>
                                    </Border>

                                </StackPanel>
                            </ScrollViewer>

                        </Grid>
                    </TabItem>

                </TabControl>
            </TabItem>

        </TabControl>
    </DockPanel>
</Window>
