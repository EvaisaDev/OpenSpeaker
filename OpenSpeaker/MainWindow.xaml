<Window x:Class="OpenSpeaker.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:OpenSpeaker.ViewModels"
        xmlns:controls="clr-namespace:OpenSpeaker.Controls"
        xmlns:views="clr-namespace:OpenSpeaker.Views"
        Title="OpenSpeaker" Height="750" Width="1280"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource Bg1}"
        Foreground="{DynamicResource TextPrimary}"
        Closing="Window_Closing">

    <!-- ══════════════════ MAIN LAYOUT ══════════════════ -->
    <DockPanel>

        <!-- ── Top header bar ── -->
        <Border DockPanel.Dock="Top" Background="{DynamicResource Bg0}"
                BorderBrush="{DynamicResource BorderBrush0}" BorderThickness="0,0,0,1" Padding="14,8">
            <DockPanel>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="{DynamicResource App.Title}" FontSize="16" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextPrimary}" Margin="0,0,20,0"
                               VerticalAlignment="Center"/>
                    <Button Content="{DynamicResource Btn.GenericSpeaker}" Style="{DynamicResource GhostButton}"
                            Command="{Binding GenericSpeakCommand}" Margin="0,0,6,0"
                            ToolTip="{DynamicResource Tip.GenericSpeaker}"/>
                </StackPanel>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <TextBlock Text="{Binding UpdateNotice}" Foreground="{DynamicResource YellowBrush}"
                               VerticalAlignment="Center" Margin="0,0,16,0"
                               Visibility="{Binding UpdateNotice, Converter={StaticResource BoolToVisibilityConverter}}"/>
                    <Button Content="{Binding Update.UpdateButtonText}" Style="{DynamicResource GhostButton}"
                            Command="{Binding Update.UpdateCommand}" Margin="0,0,12,0" VerticalAlignment="Center"
                            Foreground="{DynamicResource YellowBrush}"
                            Visibility="{Binding Update.IsUpdateAvailable, Converter={StaticResource BoolToVisibilityConverter}}"
                            ToolTip="A new version is available. Click to download and restart."/>
                    <TextBlock Text="{Binding Update.VersionText}" Style="{DynamicResource MutedText}"
                               VerticalAlignment="Center" Margin="0,0,16,0"
                               ToolTip="Current version"/>
                    <ComboBox x:Name="ProfileComboBox" Width="160"
                              ItemsSource="{Binding Profile.Profiles}"
                              SelectedItem="{Binding Profile.SelectedProfile, Mode=OneWay}"
                              SelectionChanged="ProfileComboBox_SelectionChanged"
                              ToolTip="Switch profile"/>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- ── Bottom status bar ── -->
        <Border DockPanel.Dock="Bottom" Background="{DynamicResource Bg0}"
                BorderBrush="{DynamicResource BorderBrush0}" BorderThickness="0,1,0,0" Padding="14,6">
            <DockPanel>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock VerticalAlignment="Center" Margin="0,0,12,0">
                        <Run Text="{DynamicResource Lbl.QueueCount}"/>
                        <Run Text="{Binding QueueStatus.Count, Mode=OneWay}"/>
                        <Run Text="{DynamicResource Lbl.Items}"/>
                    </TextBlock>
                    <Border Background="{DynamicResource YellowBrush}" CornerRadius="3" Padding="6,2"
                            Visibility="{Binding QueueStatus.IsPaused, Converter={StaticResource BoolToVisibilityConverter}}">
                        <TextBlock Text="{DynamicResource Lbl.Paused}" Foreground="Black" FontSize="11" FontWeight="Bold"/>
                    </Border>
                </StackPanel>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Command="{Binding QueueStatus.PauseCommand}" Margin="0,0,4,0"
                            Content="{DynamicResource Btn.Pause}" ToolTip="{DynamicResource Tip.PauseQueue}">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding QueueStatus.IsPaused}" Value="True">
                                        <Setter Property="Command" Value="{Binding QueueStatus.ResumeCommand}"/>
                                        <Setter Property="Content" Value="{DynamicResource Btn.Resume}"/>
                                        <Setter Property="ToolTip" Value="{DynamicResource Tip.ResumeQueue}"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                    <Button Content="{DynamicResource Btn.Skip}" Command="{Binding QueueStatus.StopCommand}"
                            Margin="0,0,4,0" ToolTip="{DynamicResource Tip.SkipCurrent}"/>
                    <Button Content="{DynamicResource Btn.ClearQueue}" Command="{Binding QueueStatus.ClearCommand}"
                            Style="{DynamicResource DangerButton}" ToolTip="{DynamicResource Tip.ClearQueue}"/>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- ── Main tab control ── -->
        <TabControl Margin="0">

            <!-- ═══════════════ EVENT LOG ═══════════════ -->
            <TabItem Header="{DynamicResource Tab.EventLog}">
                <DockPanel Margin="0">
                    <Border DockPanel.Dock="Top" Padding="12,8" Background="{DynamicResource Bg2}"
                            BorderBrush="{DynamicResource BorderBrush0}" BorderThickness="0,0,0,1">
                        <DockPanel>
                            <TextBlock Text="{DynamicResource Tab.EventLog}" FontSize="14" FontWeight="SemiBold" VerticalAlignment="Center"/>
                            <Button Content="{DynamicResource Btn.Clear}" HorizontalAlignment="Right"
                                    Command="{Binding EventLog.ClearCommand}" Padding="10,5"/>
                        </DockPanel>
                    </Border>
                    <ListBox ItemsSource="{Binding EventLog.Entries}"
                             ScrollViewer.VerticalScrollBarVisibility="Auto"
                             ScrollViewer.CanContentScroll="True"
                             BorderThickness="0" Background="{DynamicResource Bg1}"
                             FontFamily="Consolas" FontSize="12">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="{Binding Timestamp}" Foreground="{DynamicResource TextMuted}"
                                               Margin="0,0,10,0" FontFamily="Consolas"/>
                                    <TextBlock Text="{Binding Category}" FontWeight="SemiBold" Margin="0,0,6,0"
                                               FontFamily="Consolas">
                                        <TextBlock.Foreground>
                                            <Binding Path="Color"/>
                                        </TextBlock.Foreground>
                                    </TextBlock>
                                    <TextBlock Text="::" Foreground="{DynamicResource TextMuted}" Margin="0,0,6,0"
                                               FontFamily="Consolas"/>
                                    <TextBlock Text="{Binding Message}" Foreground="{DynamicResource TextSecondary}"
                                               FontFamily="Consolas"/>
                                </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </DockPanel>
            </TabItem>

            <!-- ═══════════════ PROCESSING ═══════════════ -->
            <TabItem Header="{DynamicResource Tab.Processing}">
                <views:ProcessingView DataContext="{Binding Processing}"/>
            </TabItem>

            <!-- ═══════════════ USERS ═══════════════ -->
            <TabItem Header="{DynamicResource Tab.Users}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="220"/>
                        <ColumnDefinition Width="1"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <DockPanel Grid.Column="0" Background="{DynamicResource Bg2}">
                        <Border DockPanel.Dock="Top" Padding="10,8"
                                BorderBrush="{DynamicResource BorderBrush0}" BorderThickness="0,0,0,1">
                            <CheckBox Content="{DynamicResource Chk.HideNotPresent}"
                                      IsChecked="{Binding Users.HideNotPresent}"
                                      ToolTip="{DynamicResource Tip.HideNotPresent}"/>
                        </Border>
                        <TextBox DockPanel.Dock="Top"
                                 Margin="8,8,8,4"
                                 Tag="Search users..."
                                 Text="{Binding Users.UserFilter, UpdateSourceTrigger=PropertyChanged}"/>
                        <ListBox ItemsSource="{Binding Users.Users}"
                                 SelectedItem="{Binding Users.SelectedUser}"
                                 BorderThickness="0" Background="Transparent" Padding="4">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding Username}" Padding="4,2"/>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </DockPanel>

                    <Border Grid.Column="1" Background="{DynamicResource BorderBrush0}"/>

                    <ScrollViewer Grid.Column="2" Padding="16">
                        <StackPanel Visibility="{Binding Users.HasSelectedUser, Converter={StaticResource BoolToVisibilityConverter}}">
                            <GroupBox Header="{StaticResource Section.UserInfo}" Margin="0,0,0,12">
                                <StackPanel>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="110"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="20"/>
                                            <ColumnDefinition Width="100"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="8"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="8"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="8"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>

                                        <TextBlock Grid.Row="0" Grid.Column="0" Text="{DynamicResource Lbl.Id}" Style="{DynamicResource MutedText}" VerticalAlignment="Center"/>
                                        <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding Users.SelectedUser.TwitchId}" IsReadOnly="True"
                                                 Background="{DynamicResource Bg3}" Foreground="{DynamicResource TextMuted}"/>
                                        <TextBlock Grid.Row="0" Grid.Column="3" Text="{DynamicResource Lbl.VoiceAlias}" Style="{DynamicResource MutedText}" VerticalAlignment="Center"/>
                                        <ComboBox Grid.Row="0" Grid.Column="4"
                                                  ItemsSource="{Binding Users.FilteredAliasNames}"
                                                  SelectedItem="{Binding Users.SelectedUser.AliasName}"
                                                  Tag="{Binding Users.AliasFilter, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                  ScrollViewer.CanContentScroll="True"
                                                  MaxDropDownHeight="300"
                                                  ToolTip="{DynamicResource Tip.UserVoiceAlias}"/>

                                        <TextBlock Grid.Row="2" Grid.Column="0" Text="{DynamicResource Lbl.Username}" Style="{DynamicResource MutedText}" VerticalAlignment="Center"/>
                                        <TextBox Grid.Row="2" Grid.Column="1" Text="{Binding Users.SelectedUser.Username}" IsReadOnly="True"
                                                 Background="{DynamicResource Bg3}" Foreground="{DynamicResource TextMuted}"/>
                                        <TextBlock Grid.Row="2" Grid.Column="3" Text="{DynamicResource Lbl.Nickname}" Style="{DynamicResource MutedText}" VerticalAlignment="Center"/>
                                        <TextBox Grid.Row="2" Grid.Column="4" Text="{Binding Users.SelectedUser.Nickname}"
                                                 ToolTip="{DynamicResource Tip.UserNickname}"/>

                                        <TextBlock Grid.Row="4" Grid.Column="0" Text="{DynamicResource Lbl.Role}" Style="{DynamicResource MutedText}" VerticalAlignment="Center"/>
                                        <TextBox Grid.Row="4" Grid.Column="1" Text="{Binding Users.SelectedUser.Role}" IsReadOnly="True"
                                                 Background="{DynamicResource Bg3}" Foreground="{DynamicResource TextMuted}"/>
                                        <TextBlock Grid.Row="4" Grid.Column="3" Text="{DynamicResource Lbl.LastActive}" Style="{DynamicResource MutedText}" VerticalAlignment="Center"/>
                                        <TextBox Grid.Row="4" Grid.Column="4"
                                                 Text="{Binding Users.SelectedUser.LastActive, StringFormat='dd/MM/yyyy HH:mm:ss'}"
                                                 IsReadOnly="True" Background="{DynamicResource Bg3}" Foreground="{DynamicResource TextMuted}"/>

                                        <StackPanel Grid.Row="6" Grid.Column="0" Grid.ColumnSpan="5" Orientation="Horizontal">
                                            <CheckBox Content="{DynamicResource Chk.Ignored}" IsChecked="{Binding Users.SelectedUser.IsIgnored}"
                                                      Margin="0,0,16,0" ToolTip="{DynamicResource Tip.UserIgnored}"/>
                                            <CheckBox Content="{DynamicResource Chk.Forced}" IsChecked="{Binding Users.SelectedUser.IsForced}"
                                                      Margin="0,0,16,0" ToolTip="{DynamicResource Tip.UserForced}"/>
                                            <CheckBox Content="{DynamicResource Chk.Regular}" IsChecked="{Binding Users.SelectedUser.IsRegular}"
                                                      Margin="0,0,16,0" ToolTip="{DynamicResource Tip.UserRegular}"/>
                                            <CheckBox Content="{DynamicResource Chk.Subscribed}" IsChecked="{Binding Users.SelectedUser.IsSubscribed}"
                                                      ToolTip="{DynamicResource Tip.UserSubscribed}"/>
                                        </StackPanel>
                                    </Grid>

                                    <Button Content="{DynamicResource Btn.SaveUser}" Command="{Binding Users.SaveUserCommand}"
                                            Style="{DynamicResource AccentButton}" Margin="0,12,0,0" HorizontalAlignment="Left"
                                            ToolTip="{DynamicResource Tip.SaveUser}"/>
                                </StackPanel>
                            </GroupBox>

                            <GroupBox Header="{StaticResource Section.PastVoices}">
                                <DataGrid ItemsSource="{Binding Users.SelectedUser.PastVoices}" Height="150"
                                          BorderThickness="0">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Binding="{Binding LastUsed, StringFormat='dd/MM/yyyy HH:mm:ss'}" Width="180">
                                            <DataGridTextColumn.Header><TextBlock Text="{DynamicResource Col.LastUsed}"/></DataGridTextColumn.Header>
                                        </DataGridTextColumn>
                                        <DataGridTextColumn Binding="{Binding EngineId}" Width="100">
                                            <DataGridTextColumn.Header><TextBlock Text="{DynamicResource Col.Engine}"/></DataGridTextColumn.Header>
                                        </DataGridTextColumn>
                                        <DataGridTextColumn Binding="{Binding VoiceId}" Width="*">
                                            <DataGridTextColumn.Header><TextBlock Text="{DynamicResource Col.VoiceId}"/></DataGridTextColumn.Header>
                                        </DataGridTextColumn>
                                    </DataGrid.Columns>
                                </DataGrid>
                            </GroupBox>
                        </StackPanel>
                    </ScrollViewer>
                </Grid>
            </TabItem>

            <!-- ═══════════════ EVENTS ═══════════════ -->
            <TabItem Header="{DynamicResource Tab.Events}">
                <Grid Margin="12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="180"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="200"/>
                    </Grid.ColumnDefinitions>

                    <DockPanel Grid.Column="0">
                        <Border DockPanel.Dock="Top" Padding="0,0,0,8">
                            <StackPanel>
                                <TextBlock Text="{DynamicResource Section.Global}" Style="{DynamicResource SectionLabel}"/>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                    <TextBlock Text="{DynamicResource Lbl.VoiceAlias}" Style="{DynamicResource MutedText}" VerticalAlignment="Center" Margin="0,0,8,0" Width="70"/>
                                    <ComboBox ItemsSource="{Binding Events.AliasNames}" SelectedItem="{Binding Events.GlobalVoiceAlias}"
                                              Width="100" ToolTip="{DynamicResource Tip.GlobalVoiceAlias}"/>
                                </StackPanel>
                                <CheckBox Content="{DynamicResource Chk.EventsEnabled}" IsChecked="{Binding Events.GlobalEventsEnabled}"
                                          Margin="0,0,0,8" ToolTip="{DynamicResource Tip.EventsGlobalEnabled}"/>
                                <Separator/>
                                <TextBlock Text="{DynamicResource Section.PerEvent}" Style="{DynamicResource SectionLabel}" Margin="0,8,0,4"/>
                            </StackPanel>
                        </Border>
                        <ListBox ItemsSource="{Binding Events.EventTypes}"
                                 SelectedItem="{Binding Events.SelectedEventType}"
                                 DisplayMemberPath="DisplayName" BorderThickness="0"
                                 Background="{DynamicResource Bg2}"/>
                    </DockPanel>

                    <DockPanel Grid.Column="1" Margin="12,0">
                        <StackPanel DockPanel.Dock="Top" Margin="0,0,0,8">
                            <StackPanel Orientation="Horizontal">
                                <CheckBox Content="{DynamicResource Chk.Enabled}" IsChecked="{Binding Events.EventEnabled}"
                                          Margin="0,0,16,0" ToolTip="{DynamicResource Tip.EventEnabled}"/>
                                <TextBlock Text="{DynamicResource Lbl.VoiceAliasSuffix}" Style="{DynamicResource MutedText}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                <ComboBox ItemsSource="{Binding Events.AliasNames}" SelectedItem="{Binding Events.EventVoiceAlias}"
                                          Width="140" ToolTip="{DynamicResource Tip.EventVoiceAlias}"/>
                            </StackPanel>
                        </StackPanel>

                        <Border DockPanel.Dock="Bottom" Background="{DynamicResource Bg2}"
                                BorderBrush="{DynamicResource BorderBrush0}" BorderThickness="1"
                                CornerRadius="5" Padding="10" Margin="0,8,0,0">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="80"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="80"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="8"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="8"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <TextBlock Grid.Row="0" Grid.Column="0" Text="{DynamicResource Lbl.Weight}" Style="{DynamicResource MutedText}" VerticalAlignment="Center"/>
                                <TextBox Grid.Row="0" Grid.Column="1"
                                         Text="{Binding Events.EditWeight, UpdateSourceTrigger=PropertyChanged}"
                                         ToolTip="{DynamicResource Tip.MessageWeight}"/>
                                <CheckBox Grid.Row="0" Grid.Column="2" Content="{DynamicResource Chk.Enabled}"
                                          IsChecked="{Binding Events.EditEnabled}" HorizontalAlignment="Right"
                                          ToolTip="{DynamicResource Tip.MessageEnabled}"/>
                                <TextBlock Grid.Row="2" Grid.Column="0" Text="{DynamicResource Lbl.Message}" Style="{DynamicResource MutedText}" VerticalAlignment="Center"/>
                                <TextBox Grid.Row="2" Grid.Column="1" Grid.ColumnSpan="2"
                                         Text="{Binding Events.EditTemplate, UpdateSourceTrigger=PropertyChanged}"
                                         ToolTip="{DynamicResource Tip.MessageTemplate}"/>
                                <StackPanel Grid.Row="4" Grid.Column="0" Grid.ColumnSpan="3" Orientation="Horizontal" HorizontalAlignment="Right">
                                    <Button Content="{DynamicResource Btn.Add}" Command="{Binding Events.AddMessageCommand}"
                                            Margin="0,0,6,0" ToolTip="{DynamicResource Tip.AddMessage}"/>
                                    <Button Content="{DynamicResource Btn.Delete}" Command="{Binding Events.DeleteMessageCommand}"
                                            Style="{DynamicResource DangerButton}" Margin="0,0,6,0"
                                            ToolTip="{DynamicResource Tip.DeleteMessage}"/>
                                    <Button Content="{DynamicResource Btn.Save}" Command="{Binding Events.SaveMessageCommand}"
                                            Style="{DynamicResource AccentButton}"
                                            ToolTip="{DynamicResource Tip.SaveMessage}"/>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <DataGrid ItemsSource="{Binding Events.Messages}"
                                  SelectedItem="{Binding Events.SelectedMessage}">
                            <DataGrid.Columns>
                                <DataGridTextColumn Binding="{Binding Weight}" Width="60">
                                    <DataGridTextColumn.Header><TextBlock Text="{DynamicResource Col.Weight}"/></DataGridTextColumn.Header>
                                </DataGridTextColumn>
                                <DataGridTextColumn Binding="{Binding Enabled}" Width="60">
                                    <DataGridTextColumn.Header><TextBlock Text="{DynamicResource Col.Enabled}"/></DataGridTextColumn.Header>
                                </DataGridTextColumn>
                                <DataGridTextColumn Binding="{Binding Template}" Width="*">
                                    <DataGridTextColumn.Header><TextBlock Text="{DynamicResource Col.Message}"/></DataGridTextColumn.Header>
                                </DataGridTextColumn>
                            </DataGrid.Columns>
                        </DataGrid>
                    </DockPanel>

                    <Border Grid.Column="2" Background="{DynamicResource Bg2}"
                            BorderBrush="{DynamicResource BorderBrush0}" BorderThickness="1"
                            CornerRadius="5" Padding="12">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <StackPanel>
                                <TextBlock Text="{DynamicResource Section.EventStates}" Style="{DynamicResource SectionLabel}" Margin="0,0,0,10"/>
                                <CheckBox Content="{DynamicResource Chk.Follows}" IsChecked="{Binding Events.FollowsEnabled}"
                                          Margin="0,0,0,8" ToolTip="{DynamicResource Tip.FollowsEnabled}"/>
                                <CheckBox Content="{DynamicResource Chk.Subscriptions}" IsChecked="{Binding Events.SubscriptionsEnabled}"
                                          Margin="0,0,0,8" ToolTip="{DynamicResource Tip.SubscriptionsEnabled}"/>
                                <CheckBox Content="{DynamicResource Chk.GiftBombs}" IsChecked="{Binding Events.GiftBombsEnabled}"
                                          Margin="0,0,0,8" ToolTip="{DynamicResource Tip.GiftBombsEnabled}"/>
                                <CheckBox Content="{DynamicResource Chk.Raids}" IsChecked="{Binding Events.RaidsEnabled}"
                                          Margin="0,0,0,4" ToolTip="{DynamicResource Tip.RaidsEnabled}"/>
                                <Grid Margin="16,0,0,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="80"/>
                                        <ColumnDefinition Width="60"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="{DynamicResource Lbl.MinViewers}" Style="{DynamicResource MutedText}" VerticalAlignment="Center"/>
                                    <TextBox Grid.Column="1" Text="{Binding Events.MinRaidViewers}"
                                             ToolTip="{DynamicResource Tip.MinRaidViewers}"/>
                                </Grid>
                                <CheckBox Content="{DynamicResource Chk.Cheers}" IsChecked="{Binding Events.CheersEnabled}"
                                          Margin="0,0,0,4" ToolTip="{DynamicResource Tip.CheersEnabled}"/>
                                <Grid Margin="16,0,0,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="80"/>
                                        <ColumnDefinition Width="60"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="{DynamicResource Lbl.MinBits}" Style="{DynamicResource MutedText}" VerticalAlignment="Center"/>
                                    <TextBox Grid.Column="1" Text="{Binding Events.MinBits}"
                                             ToolTip="{DynamicResource Tip.MinBits}"/>
                                </Grid>
                                <CheckBox Content="{DynamicResource Chk.HypeTrains}" IsChecked="{Binding Events.HypeTrainsEnabled}"
                                          Margin="0,0,0,8" ToolTip="{DynamicResource Tip.HypeTrainsEnabled}"/>
                                <CheckBox Content="{DynamicResource Chk.CommunityGoal}" IsChecked="{Binding Events.GoalEnabled}"
                                          Margin="0,0,0,8" ToolTip="{DynamicResource Tip.GoalEnabled}"/>
                                <CheckBox Content="{DynamicResource Chk.ChannelPoints}" IsChecked="{Binding Events.ChannelPointsEnabled}"
                                          Margin="0,0,0,8" ToolTip="{DynamicResource Tip.ChannelPointsEnabled}"/>
                            </StackPanel>
                        </ScrollViewer>
                    </Border>
                </Grid>
            </TabItem>

            <!-- ═══════════════ CUSTOM COMMANDS ═══════════════ -->
            <TabItem Header="{DynamicResource Tab.Commands}">
                <Grid Margin="12">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <DataGrid x:Name="CommandsDataGrid" Grid.Row="0"
                              ItemsSource="{Binding CustomCommands.Commands}"
                              SelectedItem="{Binding CustomCommands.SelectedCommand}"
                              PreviewMouseLeftButtonDown="CommandsDataGrid_PreviewMouseLeftButtonDown">
                        <DataGrid.Columns>
                            <DataGridTextColumn Binding="{Binding Trigger}" Width="Auto">
                                <DataGridTextColumn.Header><TextBlock Text="{DynamicResource Col.Command}"/></DataGridTextColumn.Header>
                            </DataGridTextColumn>
                            <DataGridTextColumn Binding="{Binding VoiceAliasName}" Width="*">
                                <DataGridTextColumn.Header><TextBlock Text="{DynamicResource Col.VoiceAlias}"/></DataGridTextColumn.Header>
                            </DataGridTextColumn>
                            <DataGridTextColumn Binding="{Binding PermissionsSummary}" Width="Auto" IsReadOnly="True">
                                <DataGridTextColumn.Header><TextBlock Text="{DynamicResource Col.Permissions}"/></DataGridTextColumn.Header>
                            </DataGridTextColumn>
                            <DataGridTemplateColumn Width="Auto">
                                <DataGridTemplateColumn.Header><TextBlock Text="{DynamicResource Col.Enabled}"/></DataGridTemplateColumn.Header>
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <CheckBox IsChecked="{Binding Enabled, UpdateSourceTrigger=PropertyChanged}"
                                                  HorizontalAlignment="Center" VerticalAlignment="Center"
                                                  Command="{Binding DataContext.CustomCommands.ToggleEnabledCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                  CommandParameter="{Binding}"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>

                    <Border Grid.Row="1" Background="{DynamicResource Bg2}"
                            BorderBrush="{DynamicResource BorderBrush0}" BorderThickness="1"
                            CornerRadius="5" Padding="12,10" Margin="0,10,0,0">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="140"/>
                                <ColumnDefinition Width="20"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="140"/>
                                <ColumnDefinition Width="16"/>
                                <ColumnDefinition Width="1" MinWidth="1"/>
                                <ColumnDefinition Width="16"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Column="0" Text="{DynamicResource Lbl.Command}" Style="{DynamicResource MutedText}"
                                       VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <TextBox Grid.Column="1" Text="{Binding CustomCommands.NewTrigger, UpdateSourceTrigger=PropertyChanged}"
                                     VerticalAlignment="Center" ToolTip="{DynamicResource Tip.CommandTrigger}"/>

                            <TextBlock Grid.Column="3" Text="{DynamicResource Lbl.VoiceAlias}" Style="{DynamicResource MutedText}"
                                       VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <ComboBox Grid.Column="4" ItemsSource="{Binding CustomCommands.AliasNames}"
                                      SelectedItem="{Binding CustomCommands.NewAlias}"
                                      VerticalAlignment="Center" ToolTip="{DynamicResource Tip.CommandVoiceAlias}">
                                <ComboBox.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding}"/>
                                    </DataTemplate>
                                </ComboBox.ItemTemplate>
                            </ComboBox>

                            <Border Grid.Column="6" Background="{DynamicResource BorderBrush0}" Width="1" Margin="0,2"/>

                            <StackPanel Grid.Column="8" Grid.ColumnSpan="2" Orientation="Horizontal" VerticalAlignment="Center">
                                <CheckBox Content="{DynamicResource Chk.Mods}" IsChecked="{Binding CustomCommands.NewAllowModerators}"
                                          Margin="0,0,12,0" ToolTip="{DynamicResource Tip.CommandMods}"/>
                                <CheckBox Content="{DynamicResource Chk.Subs}" IsChecked="{Binding CustomCommands.NewAllowSubscribers}"
                                          Margin="0,0,12,0" ToolTip="{DynamicResource Tip.CommandSubs}"/>
                                <CheckBox Content="{DynamicResource Chk.VIPs}" IsChecked="{Binding CustomCommands.NewAllowVIPs}"
                                          Margin="0,0,12,0" ToolTip="{DynamicResource Tip.CommandVips}"/>
                                <CheckBox Content="{DynamicResource Chk.Regulars}" IsChecked="{Binding CustomCommands.NewAllowRegulars}"
                                          Margin="0,0,12,0" ToolTip="{DynamicResource Tip.CommandRegulars}"/>
                                <CheckBox Content="{DynamicResource Chk.Everyone}" IsChecked="{Binding CustomCommands.NewAllowEveryone}"
                                          ToolTip="{DynamicResource Tip.CommandEveryone}"/>
                            </StackPanel>

                            <StackPanel Grid.Column="10" Orientation="Horizontal" VerticalAlignment="Center" Margin="16,0,0,0">
                                <Button Content="{Binding CustomCommands.AddSaveLabel}"
                                        Command="{Binding CustomCommands.AddSaveCommand}"
                                        Style="{DynamicResource AccentButton}" Margin="0,0,6,0"
                                        ToolTip="{DynamicResource Tip.AddSaveCommand}"/>
                                <Button Content="{DynamicResource Btn.New}" Command="{Binding CustomCommands.NewCommand}"
                                        Margin="0,0,6,0" ToolTip="{DynamicResource Tip.NewCommand}">
                                    <Button.Style>
                                        <Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding CustomCommands.IsEditing}" Value="True">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                </Button>
                                <Button Content="{DynamicResource Btn.Delete}" Command="{Binding CustomCommands.DeleteCommand}"
                                        Style="{DynamicResource DangerButton}" ToolTip="{DynamicResource Tip.DeleteCommand}"/>
                            </StackPanel>
                        </Grid>
                    </Border>
                </Grid>
            </TabItem>

            <!-- ═══════════════ CHANNEL REWARDS ═══════════════ -->
            <TabItem Header="{DynamicResource Tab.Rewards}">
                <Grid Margin="12">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <DockPanel Grid.Row="0" Margin="0,0,0,8">
                        <Button DockPanel.Dock="Right" Content="{DynamicResource Btn.RefreshFromTwitch}"
                                Command="{Binding ChannelRewards.RefreshFromTwitchCommand}"
                                Style="{DynamicResource GhostButton}"
                                ToolTip="{DynamicResource Tip.RefreshFromTwitch}"/>
                    </DockPanel>

                    <DataGrid Grid.Row="1" ItemsSource="{Binding ChannelRewards.Rewards}"
                              SelectedItem="{Binding ChannelRewards.SelectedReward}">
                        <DataGrid.Columns>
                            <DataGridTextColumn Binding="{Binding Title}" Width="*">
                                <DataGridTextColumn.Header><TextBlock Text="{DynamicResource Col.RewardName}"/></DataGridTextColumn.Header>
                            </DataGridTextColumn>
                            <DataGridTextColumn Binding="{Binding Cost}" Width="80">
                                <DataGridTextColumn.Header><TextBlock Text="{DynamicResource Col.Cost}"/></DataGridTextColumn.Header>
                            </DataGridTextColumn>
                            <DataGridTextColumn Binding="{Binding IsIgnored}" Width="70">
                                <DataGridTextColumn.Header><TextBlock Text="{DynamicResource Col.Ignored}"/></DataGridTextColumn.Header>
                            </DataGridTextColumn>
                            <DataGridTextColumn Binding="{Binding SayInput}" Width="Auto">
                                <DataGridTextColumn.Header><TextBlock Text="{DynamicResource Col.SayInput}"/></DataGridTextColumn.Header>
                            </DataGridTextColumn>
                            <DataGridTextColumn Binding="{Binding VoiceAliasName}" Width="120">
                                <DataGridTextColumn.Header><TextBlock Text="{DynamicResource Col.VoiceAlias}"/></DataGridTextColumn.Header>
                            </DataGridTextColumn>
                        </DataGrid.Columns>
                    </DataGrid>

                    <Border Grid.Row="2" Background="{DynamicResource Bg2}"
                            BorderBrush="{DynamicResource BorderBrush0}" BorderThickness="1"
                            CornerRadius="5" Padding="12" Margin="0,10,0,0"
                            Visibility="{Binding ChannelRewards.HasSelected, Converter={StaticResource BoolToVisibilityConverter}}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="16"/>
                                <ColumnDefinition Width="220"/>
                            </Grid.ColumnDefinitions>

                            <DockPanel Grid.Column="0">
                                <TextBlock DockPanel.Dock="Top" Text="{DynamicResource Section.RewardMessages}" Style="{DynamicResource SectionLabel}" Margin="0,0,0,6"/>
                                <DataGrid DockPanel.Dock="Top" ItemsSource="{Binding ChannelRewards.Messages}"
                                          SelectedItem="{Binding ChannelRewards.SelectedMessage}" Height="100">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Binding="{Binding Weight}" Width="60">
                                            <DataGridTextColumn.Header><TextBlock Text="{DynamicResource Col.Weight}"/></DataGridTextColumn.Header>
                                        </DataGridTextColumn>
                                        <DataGridTextColumn Binding="{Binding Enabled}" Width="60">
                                            <DataGridTextColumn.Header><TextBlock Text="{DynamicResource Col.Enabled}"/></DataGridTextColumn.Header>
                                        </DataGridTextColumn>
                                        <DataGridTextColumn Binding="{Binding Template}" Width="*">
                                            <DataGridTextColumn.Header><TextBlock Text="{DynamicResource Col.Message}"/></DataGridTextColumn.Header>
                                        </DataGridTextColumn>
                                    </DataGrid.Columns>
                                </DataGrid>
                                <Grid Margin="0,8,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="60"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="70"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="6"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="6"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <TextBlock Grid.Row="0" Grid.Column="0" Text="{DynamicResource Lbl.Weight}" Style="{DynamicResource MutedText}" VerticalAlignment="Center"/>
                                    <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding ChannelRewards.EditWeight}"
                                             ToolTip="{DynamicResource Tip.MessageWeight}"/>
                                    <CheckBox Grid.Row="0" Grid.Column="2" Content="{DynamicResource Chk.Enabled}"
                                              IsChecked="{Binding ChannelRewards.EditEnabled}" HorizontalAlignment="Right"
                                              ToolTip="{DynamicResource Tip.MessageEnabled}"/>
                                    <TextBlock Grid.Row="2" Grid.Column="0" Text="{DynamicResource Lbl.Message}" Style="{DynamicResource MutedText}" VerticalAlignment="Center"/>
                                    <TextBox Grid.Row="2" Grid.Column="1" Grid.ColumnSpan="2" Text="{Binding ChannelRewards.EditTemplate}"
                                             ToolTip="{DynamicResource Tip.MessageTemplate}"/>
                                    <StackPanel Grid.Row="4" Grid.Column="0" Grid.ColumnSpan="3" Orientation="Horizontal" HorizontalAlignment="Right">
                                        <Button Content="{DynamicResource Btn.Add}" Command="{Binding ChannelRewards.AddMessageCommand}"
                                                Margin="0,0,4,0" ToolTip="{DynamicResource Tip.AddMessage}"/>
                                        <Button Content="{DynamicResource Btn.Delete}" Command="{Binding ChannelRewards.DeleteMessageCommand}"
                                                Style="{DynamicResource DangerButton}" Margin="0,0,4,0"
                                                ToolTip="{DynamicResource Tip.DeleteMessage}"/>
                                        <Button Content="{DynamicResource Btn.Save}" Command="{Binding ChannelRewards.SaveMessageCommand}"
                                                Style="{DynamicResource AccentButton}"
                                                ToolTip="{DynamicResource Tip.SaveMessage}"/>
                                    </StackPanel>
                                </Grid>
                            </DockPanel>

                            <StackPanel Grid.Column="2">
                                <TextBlock Text="{DynamicResource Section.Settings}" Style="{DynamicResource SectionLabel}" Margin="0,0,0,10"/>
                                <CheckBox Content="{DynamicResource Chk.Ignored}" IsChecked="{Binding ChannelRewards.SelectedReward.IsIgnored}"
                                          Margin="0,0,0,8" ToolTip="{DynamicResource Tip.RewardIgnored}"/>
                                <CheckBox Content="{DynamicResource Chk.SayInput}" IsChecked="{Binding ChannelRewards.SelectedReward.SayInput}"
                                          Margin="0,0,0,8" ToolTip="{DynamicResource Tip.RewardSayInput}"/>
                                <TextBlock Text="{DynamicResource Lbl.VoiceAlias}" Style="{DynamicResource MutedText}" Margin="0,0,0,4"/>
                                <ComboBox ItemsSource="{Binding ChannelRewards.AliasNames}"
                                          SelectedItem="{Binding ChannelRewards.SelectedReward.VoiceAliasName}"
                                          ToolTip="{DynamicResource Tip.RewardVoiceAlias}"/>
                                <Button Content="{DynamicResource Btn.SaveReward}" Command="{Binding ChannelRewards.SaveRewardCommand}"
                                        Style="{DynamicResource AccentButton}" Margin="0,12,0,4"
                                        ToolTip="{DynamicResource Tip.SaveReward}"/>
                                <Button Content="{DynamicResource Btn.RemoveReward}" Command="{Binding ChannelRewards.RemoveRewardCommand}"
                                        Style="{DynamicResource DangerButton}"
                                        ToolTip="{DynamicResource Tip.RemoveReward}"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                </Grid>
            </TabItem>

            <!-- ═══════════════ SETTINGS ═══════════════ -->
            <TabItem Header="{DynamicResource Tab.Settings}">
                <TabControl>

                    <!-- ─── General ─── -->
                    <TabItem Header="{DynamicResource Tab.General}">
                        <ScrollViewer Padding="16">
                            <StackPanel>
                                <Grid Margin="0,0,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="12"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- Left column -->
                                    <StackPanel Grid.Column="0">
                                        <GroupBox Header="{StaticResource Section.Instance}" Margin="0,0,0,12">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="80"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="8"/>
                                                    <RowDefinition Height="Auto"/>
                                                </Grid.RowDefinitions>
                                                <TextBlock Grid.Row="0" Grid.Column="0" Text="{DynamicResource Lbl.Id}" Style="{DynamicResource MutedText}" VerticalAlignment="Center"/>
                                                <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding GeneralSettings.InstanceId, Mode=OneWay}" IsReadOnly="True"
                                                         Background="{DynamicResource Bg3}" Foreground="{DynamicResource TextMuted}"
                                                         ToolTip="{DynamicResource Tip.InstanceId}"/>
                                                <Button Grid.Row="0" Grid.Column="2" Content="{DynamicResource Btn.Reset}"
                                                        Command="{Binding GeneralSettings.ResetInstanceIdCommand}" Margin="6,0,0,0"
                                                        ToolTip="{DynamicResource Tip.ResetInstanceId}"/>
                                                <TextBlock Grid.Row="2" Grid.Column="0" Text="{DynamicResource Lbl.Name}" Style="{DynamicResource MutedText}" VerticalAlignment="Center"/>
                                                <TextBox Grid.Row="2" Grid.Column="1" Grid.ColumnSpan="2" Text="{Binding GeneralSettings.InstanceName}"
                                                         ToolTip="{DynamicResource Tip.InstanceName}"/>
                                            </Grid>
                                        </GroupBox>

                                        <GroupBox Header="{StaticResource Section.Flags}" Margin="0,0,0,12">
                                            <CheckBox Content="{DynamicResource Chk.Enabled}" IsChecked="{Binding GeneralSettings.Enabled}"
                                                      ToolTip="{DynamicResource Tip.GeneralEnabled}"/>
                                        </GroupBox>

                                        <GroupBox Header="{StaticResource Section.WindowBehaviour}" Margin="0,0,0,12">
                                            <StackPanel>
                                                <CheckBox Content="{DynamicResource Chk.MinimizeToTray}" IsChecked="{Binding GeneralSettings.MinimizeToTray}"
                                                          Margin="0,0,0,8" ToolTip="{DynamicResource Tip.MinimizeToTray}"/>
                                                <CheckBox Content="{DynamicResource Chk.ConfirmationOnClose}" IsChecked="{Binding GeneralSettings.ConfirmationOnClose}"
                                                          Margin="0,0,0,8" ToolTip="{DynamicResource Tip.ConfirmationOnClose}"/>
                                                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                                    <TextBlock Text="{DynamicResource Lbl.LogLevel}" Style="{DynamicResource MutedText}" VerticalAlignment="Center" Margin="0,0,10,0"/>
                                                    <ComboBox ItemsSource="{Binding GeneralSettings.LogLevels}"
                                                              SelectedItem="{Binding GeneralSettings.LogLevel}" Width="120"
                                                              ToolTip="{DynamicResource Tip.LogLevel}"/>
                                                </StackPanel>
                                                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                                    <TextBlock Text="{DynamicResource Lbl.Language}" Style="{DynamicResource MutedText}" VerticalAlignment="Center" Margin="0,0,10,0"/>
                                                    <ComboBox ItemsSource="{Binding GeneralSettings.AvailableLanguages}"
                                                              SelectedItem="{Binding GeneralSettings.Language}" Width="120"
                                                              ToolTip="{DynamicResource Tip.Language}"/>
                                                    <Button Content="Refresh" Command="{Binding GeneralSettings.RefreshLanguagesCommand}"
                                                            Margin="6,0,0,0" Padding="8,2"
                                                            ToolTip="Re-scan the Localization folder for added languages"/>
                                                    <Button Content="Open Folder" Command="{Binding GeneralSettings.OpenLanguagesFolderCommand}"
                                                            Margin="6,0,0,0" Padding="8,2"
                                                            ToolTip="Open the Localization folder where custom language files can be added"/>
                                                </StackPanel>
                                                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                                    <TextBlock Text="Theme" Style="{DynamicResource MutedText}" VerticalAlignment="Center" Margin="0,0,10,0"/>
                                                    <ComboBox ItemsSource="{Binding GeneralSettings.AvailableThemes}"
                                                              SelectedItem="{Binding GeneralSettings.Theme}" Width="120"/>
                                                    <Button Content="Refresh" Command="{Binding GeneralSettings.RefreshThemesCommand}"
                                                            Margin="6,0,0,0" Padding="8,2"
                                                            ToolTip="Re-scan the Themes folder for added themes"/>
                                                    <Button Content="Open Folder" Command="{Binding GeneralSettings.OpenThemesFolderCommand}"
                                                            Margin="6,0,0,0" Padding="8,2"
                                                            ToolTip="Open the Themes folder where custom theme files can be added"/>
                                                </StackPanel>
                                                <CheckBox Content="{DynamicResource Chk.ShowTooltips}" IsChecked="{Binding GeneralSettings.ShowTooltips}"
                                                          ToolTip="{DynamicResource Tip.ShowTooltips}"/>
                                            </StackPanel>
                                        </GroupBox>

                                    </StackPanel>

                                    <!-- Right column -->
                                    <StackPanel Grid.Column="2">
                                        <GroupBox Header="{StaticResource Section.AudioOutput}" Margin="0,0,0,12">
                                            <StackPanel>
                                                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                                    <ComboBox ItemsSource="{Binding GeneralSettings.OutputDevices}"
                                                              SelectedValuePath="Id"
                                                              SelectedValue="{Binding GeneralSettings.AudioOutputDeviceId}"
                                                              ToolTip="{DynamicResource Tip.AudioDevice}">
                                                        <ComboBox.ItemTemplate>
                                                            <DataTemplate>
                                                                <TextBlock Text="{Binding Name}"/>
                                                            </DataTemplate>
                                                        </ComboBox.ItemTemplate>
                                                    </ComboBox>
                                                    <Button Content="{DynamicResource Btn.Refresh}" Command="{Binding GeneralSettings.RefreshDevicesCommand}"
                                                            Margin="8,0,0,0" ToolTip="{DynamicResource Tip.RefreshDevices}"/>
                                                </StackPanel>
                                                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                                    <TextBlock Text="{DynamicResource Lbl.Volume}" Style="{DynamicResource MutedText}" VerticalAlignment="Center" Margin="0,0,10,0"/>
                                                    <controls:NumericSlider Minimum="0" Maximum="100"
                                                            Value="{Binding GeneralSettings.ApplicationVolume}"
                                                            SliderWidth="160" Suffix="%"
                                                            ToolTip="{DynamicResource Tip.Volume}"/>
                                                </StackPanel>
                                                <CheckBox Content="{DynamicResource Chk.DisableAudioOutput}"
                                                          IsChecked="{Binding GeneralSettings.DisableAudioOutput}"
                                                          Margin="0,0,0,6"
                                                          ToolTip="{DynamicResource Tip.DisableAudioOutput}"/>
                                                <TextBlock Text="{DynamicResource Lbl.QueueMode}" Margin="0,0,0,4"/>
                                                <ComboBox ItemsSource="{Binding GeneralSettings.QueueModes}"
                                                          SelectedItem="{Binding GeneralSettings.QueueMode}"
                                                          ToolTip="{DynamicResource Tip.QueueMode}"/>
                                            </StackPanel>
                                        </GroupBox>

                                        <GroupBox Header="{StaticResource Section.SaveTtsToFile}" Margin="0,0,0,12">
                                            <StackPanel>
                                                <CheckBox Content="{DynamicResource Chk.SaveTtsToFile}"
                                                          IsChecked="{Binding GeneralSettings.SaveTts}" Margin="0,0,0,8"
                                                          ToolTip="{DynamicResource Tip.SaveTts}"/>
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBox Text="{Binding GeneralSettings.SaveTtsFolder}" Width="220"
                                                             ToolTip="{DynamicResource Tip.SaveTtsFolder}"/>
                                                    <Button Content="{DynamicResource Btn.Browse}" Command="{Binding GeneralSettings.BrowseFolderCommand}"
                                                            Margin="6,0,0,0" Padding="10,5"
                                                            ToolTip="{DynamicResource Tip.BrowseTtsFolder}"/>
                                                </StackPanel>
                                            </StackPanel>
                                        </GroupBox>

                                        <GroupBox Header="{StaticResource Section.DefaultAliases}" Margin="0,0,0,12">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="130"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="8"/>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="8"/>
                                                    <RowDefinition Height="Auto"/>
                                                </Grid.RowDefinitions>
                                                <TextBlock Grid.Row="0" Grid.Column="0" Text="{DynamicResource Lbl.DefaultVoiceAlias}" Style="{DynamicResource MutedText}" VerticalAlignment="Center"/>
                                                <ComboBox Grid.Row="0" Grid.Column="1"
                                                          ItemsSource="{Binding GeneralSettings.AvailableAliases}"
                                                          SelectedItem="{Binding GeneralSettings.DefaultVoiceAlias}"
                                                          ToolTip="{DynamicResource Tip.DefaultVoiceAlias}"/>
                                                <CheckBox Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2"
                                                          Content="{DynamicResource Chk.UseHighlightVoice}"
                                                          IsChecked="{Binding GeneralSettings.UseHighlightVoice}"
                                                          ToolTip="{DynamicResource Tip.UseHighlightVoice}"/>
                                                <TextBlock Grid.Row="4" Grid.Column="0" Text="{DynamicResource Lbl.HighlightVoiceAlias}" Style="{DynamicResource MutedText}" VerticalAlignment="Center"/>
                                                <ComboBox Grid.Row="4" Grid.Column="1"
                                                          ItemsSource="{Binding GeneralSettings.AvailableAliases}"
                                                          SelectedItem="{Binding GeneralSettings.HighlightVoiceAlias}"
                                                          ToolTip="{DynamicResource Tip.HighlightVoiceAlias}"/>
                                            </Grid>
                                        </GroupBox>
                                    </StackPanel>
                                </Grid>

                                <GroupBox Header="{StaticResource Section.ImportSpeakerBot}" Margin="0,12,0,12">
                                    <StackPanel>
                                        <TextBlock Text="{DynamicResource Lbl.ImportSpeakerBotDesc}" Style="{DynamicResource MutedText}" TextWrapping="Wrap" Margin="0,0,0,8"/>
                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                            <TextBox Text="{Binding Import.FolderPath}" Width="280" IsReadOnly="True"
                                                     ToolTip="{DynamicResource Tip.ImportFolder}"/>
                                            <Button Content="{DynamicResource Btn.Browse}" Command="{Binding Import.BrowseFolderCommand}"
                                                    Margin="6,0,0,0" Padding="10,5"
                                                    ToolTip="{DynamicResource Tip.BrowseImportFolder}"/>
                                        </StackPanel>
                                        <Button Content="{DynamicResource Btn.ImportNow}" Command="{Binding Import.ImportCommand}"
                                                Style="{DynamicResource AccentButton}" HorizontalAlignment="Left" Margin="0,0,0,8"
                                                ToolTip="{DynamicResource Tip.ImportNow}"/>
                                    </StackPanel>
                                </GroupBox>

                            </StackPanel>
                        </ScrollViewer>
                    </TabItem>

                    <!-- ─── Accounts ─── -->
                    <TabItem Header="{DynamicResource Tab.Accounts}">
                        <TabControl>
                            <TabItem Header="{DynamicResource Tab.Twitch}">
                                <Grid Margin="16">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="12"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <GroupBox Grid.Column="0" Header="{StaticResource Section.Account}">
                                        <StackPanel>
                                            <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                                <Border Width="48" Height="48" CornerRadius="24"
                                                        Background="{DynamicResource Bg4}" Margin="0,0,12,0"
                                                        ClipToBounds="True">
                                                    <Grid>
                                                        <TextBlock Text="T" HorizontalAlignment="Center" VerticalAlignment="Center"
                                                                   FontSize="18" FontWeight="Bold" Foreground="{DynamicResource AccentBrush}"/>
                                                        <Image Source="{Binding Accounts.TwitchAvatarUrl}" Stretch="UniformToFill"/>
                                                    </Grid>
                                                </Border>
                                                <StackPanel VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding Accounts.TwitchLogin}" FontSize="15" FontWeight="SemiBold"/>
                                                    <TextBlock Text="{Binding Accounts.TwitchBroadcasterType}" Style="{DynamicResource MutedText}"/>
                                                </StackPanel>
                                            </StackPanel>
                                            <StackPanel Orientation="Horizontal">
                                                <Button Content="{DynamicResource Btn.Login}" Command="{Binding Accounts.TwitchConnectCommand}"
                                                        Style="{DynamicResource AccentButton}" Margin="0,0,8,0"
                                                        ToolTip="{DynamicResource Tip.TwitchLogin}"/>
                                                <Button Content="{DynamicResource Btn.Logout}" Command="{Binding Accounts.TwitchLogoutCommand}"
                                                        Margin="0,0,8,0" ToolTip="{DynamicResource Tip.TwitchLogout}"/>
                                                <Button Content="{DynamicResource Btn.Forget}" Command="{Binding Accounts.TwitchForgetCommand}"
                                                        Style="{DynamicResource DangerButton}"
                                                        ToolTip="{DynamicResource Tip.TwitchForget}"/>
                                            </StackPanel>
                                        </StackPanel>
                                    </GroupBox>

                                    <GroupBox Grid.Column="2" Header="{StaticResource Section.Services}">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="90"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="8"/>
                                                <RowDefinition Height="Auto"/>
                                            </Grid.RowDefinitions>
                                            <TextBlock Grid.Row="0" Grid.Column="0" Text="{DynamicResource Lbl.ChatClient}" Style="{DynamicResource MutedText}" VerticalAlignment="Center"/>
                                            <Button Grid.Row="0" Grid.Column="1" Content="{Binding Accounts.ChatClientStatus}"
                                                    Command="{Binding Accounts.ChatClientToggleCommand}" HorizontalAlignment="Left"
                                                    ToolTip="{DynamicResource Tip.ChatClientToggle}"/>
                                            <TextBlock Grid.Row="2" Grid.Column="0" Text="{DynamicResource Lbl.EventSub}" Style="{DynamicResource MutedText}" VerticalAlignment="Center"/>
                                            <Button Grid.Row="2" Grid.Column="1" Content="{Binding Accounts.EventSubStatus}"
                                                    Command="{Binding Accounts.EventSubToggleCommand}" HorizontalAlignment="Left"
                                                    ToolTip="{DynamicResource Tip.EventSubToggle}"/>
                                        </Grid>
                                    </GroupBox>
                                </Grid>
                            </TabItem>
                        </TabControl>
                    </TabItem>

                    <!-- ─── Voice Gate ─── -->
                    <TabItem Header="{DynamicResource Tab.VoiceGate}">
                        <Grid Margin="16">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="16"/>
                                    <ColumnDefinition Width="260"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0">
                                    <GroupBox Header="{StaticResource Section.AudioDeviceToMonitor}" Margin="0,0,0,12">
                                        <StackPanel>
                                            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                                <ComboBox ItemsSource="{Binding VoiceGate.InputDevices}"
                                                          SelectedItem="{Binding VoiceGate.SelectedDevice}"
                                                          Width="200" ToolTip="{DynamicResource Tip.VoiceGateDevice}">
                                                    <ComboBox.ItemTemplate>
                                                        <DataTemplate>
                                                            <TextBlock Text="{Binding Name}"/>
                                                        </DataTemplate>
                                                    </ComboBox.ItemTemplate>
                                                </ComboBox>
                                                <Button Content="{DynamicResource Btn.Refresh}" Command="{Binding VoiceGate.RefreshDevicesCommand}"
                                                        Margin="8,0,0,0" ToolTip="{DynamicResource Tip.RefreshGateDevices}"/>
                                            </StackPanel>
                                            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                                <Button Content="{DynamicResource Btn.Start}" Command="{Binding VoiceGate.StartCommand}"
                                                        Style="{DynamicResource AccentButton}" Margin="0,0,8,0"
                                                        ToolTip="{DynamicResource Tip.StartVoiceGate}"/>
                                                <Button Content="{DynamicResource Btn.Stop}" Command="{Binding VoiceGate.StopCommand}"
                                                        Margin="0,0,16,0" ToolTip="{DynamicResource Tip.StopVoiceGate}"/>
                                                <CheckBox Content="{DynamicResource Chk.AutoStart}" IsChecked="{Binding VoiceGate.AutoStart}"
                                                          VerticalAlignment="Center" ToolTip="{DynamicResource Tip.VoiceGateAutoStart}"/>
                                            </StackPanel>
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="{DynamicResource Lbl.Volume}" Style="{DynamicResource MutedText}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                                <ProgressBar Value="{Binding VoiceGate.Volume}" Width="200" Maximum="100"/>
                                                <TextBlock Margin="8,0,0,0" VerticalAlignment="Center">
                                                    <Run Text="{Binding VoiceGate.Volume, StringFormat='0'}"/>
                                                    <Run Text="{DynamicResource Lbl.Percent}"/>
                                                </TextBlock>
                                            </StackPanel>
                                        </StackPanel>
                                    </GroupBox>

                                    <GroupBox Header="{StaticResource Section.Profiles}">
                                        <DockPanel>
                                            <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" Margin="0,8,0,0">
                                                <TextBox Text="{Binding VoiceGate.NewProfileName}" Width="140" Margin="0,0,6,0"/>
                                                <Button Content="{DynamicResource Btn.AddProfile}" Command="{Binding VoiceGate.AddProfileCommand}"
                                                        Margin="0,0,6,0" ToolTip="{DynamicResource Tip.AddVoiceGateProfile}"/>
                                                <Button Content="{DynamicResource Btn.Delete}" Command="{Binding VoiceGate.DeleteProfileCommand}"
                                                        Style="{DynamicResource DangerButton}"
                                                        ToolTip="{DynamicResource Tip.DeleteVoiceGateProfile}"/>
                                            </StackPanel>
                                            <DataGrid ItemsSource="{Binding VoiceGate.Profiles}"
                                                      SelectedItem="{Binding VoiceGate.SelectedProfile}" Height="120">
                                                <DataGrid.Columns>
                                                    <DataGridTextColumn Binding="{Binding Name}" Width="*">
                                                        <DataGridTextColumn.Header><TextBlock Text="{DynamicResource Col.Name}"/></DataGridTextColumn.Header>
                                                    </DataGridTextColumn>
                                                    <DataGridTextColumn Binding="{Binding DeviceId}" Width="130">
                                                        <DataGridTextColumn.Header><TextBlock Text="{DynamicResource Col.Device}"/></DataGridTextColumn.Header>
                                                    </DataGridTextColumn>
                                                    <DataGridTextColumn Binding="{Binding ThresholdDb}" Width="90">
                                                        <DataGridTextColumn.Header><TextBlock Text="{DynamicResource Col.Threshold}"/></DataGridTextColumn.Header>
                                                    </DataGridTextColumn>
                                                    <DataGridTextColumn Binding="{Binding TimeoutMs}" Width="90">
                                                        <DataGridTextColumn.Header><TextBlock Text="{DynamicResource Col.TimeoutMs}"/></DataGridTextColumn.Header>
                                                    </DataGridTextColumn>
                                                </DataGrid.Columns>
                                            </DataGrid>
                                        </DockPanel>
                                    </GroupBox>
                                </StackPanel>

                                <Border Grid.Column="2" Background="{DynamicResource Bg2}"
                                        BorderBrush="{DynamicResource BorderBrush0}" BorderThickness="1"
                                        CornerRadius="5" Padding="12">
                                    <StackPanel>
                                        <TextBlock Text="{DynamicResource Section.Settings}" Style="{DynamicResource SectionLabel}" Margin="0,0,0,12"/>
                                        <TextBlock>
                                            <Run Text="{DynamicResource Lbl.PauseThreshold}"/>
                                            <Run Text="{Binding VoiceGate.PauseThreshold}"/>
                                            <Run Text="{DynamicResource Lbl.Percent}"/>
                                        </TextBlock>
                                        <controls:NumericSlider Minimum="0" Maximum="100" Value="{Binding VoiceGate.PauseThreshold}"
                                                Suffix="%" Margin="0,6,0,12" ToolTip="{DynamicResource Tip.PauseThreshold}"/>
                                        <TextBlock>
                                            <Run Text="{DynamicResource Lbl.ResumeThreshold}"/>
                                            <Run Text="{Binding VoiceGate.ResumeThreshold}"/>
                                            <Run Text="{DynamicResource Lbl.Percent}"/>
                                        </TextBlock>
                                        <controls:NumericSlider Minimum="0" Maximum="100" Value="{Binding VoiceGate.ResumeThreshold}"
                                                Suffix="%" Margin="0,6,0,12" ToolTip="{DynamicResource Tip.ResumeThreshold}"/>
                                        <TextBlock Text="{DynamicResource Lbl.ResumeWaitTimeout}" Style="{DynamicResource MutedText}" Margin="0,0,0,4"/>
                                        <StackPanel Orientation="Horizontal">
                                            <TextBox Text="{Binding VoiceGate.ResumeWaitMs}" Width="80"
                                                     ToolTip="{DynamicResource Tip.ResumeWaitMs}"/>
                                            <TextBlock Text="{DynamicResource Lbl.Ms}" Style="{DynamicResource MutedText}" VerticalAlignment="Center" Margin="8,0,0,0"/>
                                        </StackPanel>
                                    </StackPanel>
                                </Border>
                        </Grid>
                    </TabItem>

                    <!-- ─── Speech Engines ─── -->
                    <TabItem Header="{DynamicResource Tab.SpeechEngines}">
                        <Grid Margin="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="180"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <DockPanel Grid.Column="0">
                                <TextBlock DockPanel.Dock="Top" Text="{DynamicResource Section.Engines}" Style="{DynamicResource SectionLabel}" Margin="0,0,0,4"/>
                                <UniformGrid DockPanel.Dock="Bottom" Columns="3" Margin="0,8,0,0">
                                    <Button Content="{DynamicResource Btn.Add}" Command="{Binding SpeechEngines.ShowAddDialogCommand}"
                                            Margin="0,0,2,0" ToolTip="{DynamicResource Tip.AddEngine}"/>
                                    <Button Content="{DynamicResource Btn.Remove}" Command="{Binding SpeechEngines.RemoveCommand}"
                                            Style="{DynamicResource DangerButton}"
                                            Margin="0,0,2,0"
                                            ToolTip="{DynamicResource Tip.RemoveEngine}"/>
                                    <Button Content="{DynamicResource Btn.Reload}" Command="{Binding SpeechEngines.ReloadCommand}"/>
                                </UniformGrid>
                                <ListBox ItemsSource="{Binding SpeechEngines.Engines}"
                                         SelectedItem="{Binding SpeechEngines.SelectedEngine}"
                                         BorderThickness="0"
                                         Background="{DynamicResource Bg2}">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding DisplayName}"/>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                            </DockPanel>

                            <DockPanel Grid.Column="1" Margin="12,0,0,0">
