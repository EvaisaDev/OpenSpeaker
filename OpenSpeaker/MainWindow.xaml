                                        <DataTemplate><TextBlock Text="{Binding}" Padding="2,1" FontSize="12"/></DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>

                                <StackPanel Grid.Row="1" Grid.Column="1" VerticalAlignment="Center" HorizontalAlignment="Center">
                                    <Button Content="{DynamicResource Btn.IgnoreArrow}" Command="{Binding IgnoredVoices.IgnoreVoiceCommand}"
                                            Padding="8,6" Margin="0,4" ToolTip="{DynamicResource Tip.IgnoreVoice}"/>
                                    <Button Content="{DynamicResource Btn.UnignoreArrow}" Command="{Binding IgnoredVoices.UnignoreVoiceCommand}"
                                            Padding="8,6" Margin="0,4" ToolTip="{DynamicResource Tip.UnignoreVoice}"/>
                                </StackPanel>

                                <ListBox Grid.Row="1" Grid.Column="2"
                                         ItemsSource="{Binding IgnoredVoices.IgnoredVoices}"
                                         SelectedItem="{Binding IgnoredVoices.SelectedIgnoredVoice}">
