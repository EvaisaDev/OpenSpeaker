<UserControl x:Class="OpenSpeaker.Controls.NumericSlider"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             VerticalAlignment="Center">
    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
        <Slider x:Name="PART_Slider" VerticalAlignment="Center"/>
        <TextBlock x:Name="PART_Display" VerticalAlignment="Center" Margin="8,0,0,0"
                   Cursor="Hand" MouseLeftButtonDown="OnDisplayClick"
                   MouseRightButtonDown="OnDisplayRightClick"/>
        <TextBox x:Name="PART_Input" VerticalAlignment="Center" Margin="8,0,0,0"
                 MinWidth="40" Visibility="Collapsed"
                 LostFocus="OnInputLostFocus" KeyDown="OnInputKeyDown"/>
    </StackPanel>
</UserControl>
