<Window x:Class="OpenSpeaker.Views.ChangelogWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="What's New" Width="560" Height="600"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource Bg1}"
        Foreground="{StaticResource TextPrimary}">
    <DockPanel Margin="16">
        <StackPanel DockPanel.Dock="Top" Margin="0,0,0,12">
            <TextBlock Text="What's New" FontSize="20" FontWeight="Bold"/>
            <TextBlock x:Name="VersionLabel" Style="{StaticResource MutedText}" Margin="0,2,0,0"/>
        </StackPanel>

        <Button DockPanel.Dock="Bottom" Content="Close" Click="Close_Click"
                Style="{StaticResource AccentButton}"
                Height="34" Width="120" HorizontalAlignment="Right" Margin="0,12,0,0"/>

        <ScrollViewer VerticalScrollBarVisibility="Auto"
                      Background="{StaticResource Bg2}"
                      BorderBrush="{StaticResource BorderBrush0}" BorderThickness="1"
                      Padding="14,10">
            <StackPanel x:Name="ContentPanel"/>
        </ScrollViewer>
    </DockPanel>
</Window>
