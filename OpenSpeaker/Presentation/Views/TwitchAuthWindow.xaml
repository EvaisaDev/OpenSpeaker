<Window x:Class="OpenSpeaker.Views.TwitchAuthWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Twitch Login" Height="200" Width="420"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource Bg1}"
        Foreground="{StaticResource TextPrimary}">
    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
        <TextBlock Text="A browser window has been opened." FontSize="14" HorizontalAlignment="Center" Margin="0,0,0,6"/>
        <TextBlock Text="Log in with Twitch to complete authentication." Style="{StaticResource MutedText}" HorizontalAlignment="Center" Margin="0,0,0,20"/>
        <TextBlock x:Name="StatusText" Text="Waiting for authentication..." Style="{StaticResource MutedText}" HorizontalAlignment="Center" Margin="0,0,0,20"/>
        <Button Content="Cancel" HorizontalAlignment="Center" Padding="20,7" Click="Cancel_Click"/>
    </StackPanel>
</Window>
