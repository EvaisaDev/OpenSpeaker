<Window x:Class="OpenSpeaker.Views.Dialogs.CreateProfileDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Create Profile" SizeToContent="Height" Width="300"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Background="{DynamicResource Bg1}"
        Foreground="{DynamicResource TextPrimary}">
    <StackPanel Margin="16">
        <TextBlock Text="Profile name" Foreground="{DynamicResource TextMuted}" Margin="0,0,0,6"/>
        <TextBox x:Name="NameBox" KeyDown="NameBox_KeyDown" Margin="0,0,0,16"/>
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Cancel" Width="75" Margin="0,0,8,0" Click="Cancel_Click"/>
            <Button Content="Create" Width="75" Click="Create_Click"/>
        </StackPanel>
    </StackPanel>
</Window>
