<Window x:Class="OpenSpeaker.Views.Dialogs.VoiceAliasEditDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Voice Alias" Height="420" Width="480"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="{DynamicResource Bg1}"
        Foreground="{DynamicResource TextPrimary}">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="120"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <TextBlock Grid.Row="0" Grid.Column="0" Text="Name:" VerticalAlignment="Center" Margin="0,6"/>
        <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}" Margin="0,4"/>

        <TextBlock Grid.Row="1" Grid.Column="0" Text="Engine:" VerticalAlignment="Center" Margin="0,6"/>
        <ComboBox Grid.Row="1" Grid.Column="1" ItemsSource="{Binding AvailableEngineTypes}" SelectedItem="{Binding EngineType}" Margin="0,4"/>

        <TextBlock Grid.Row="2" Grid.Column="0" Text="Voice:" VerticalAlignment="Center" Margin="0,6"/>
        <Grid Grid.Row="2" Grid.Column="1" Margin="0,4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <ComboBox Grid.Column="0" ItemsSource="{Binding AvailableVoices}" SelectedValuePath="Id" DisplayMemberPath="Name" SelectedValue="{Binding VoiceId}"
                      ScrollViewer.CanContentScroll="True" MaxDropDownHeight="300">
                <ComboBox.ItemsPanel>
                    <ItemsPanelTemplate><VirtualizingStackPanel IsVirtualizing="True" VirtualizationMode="Recycling"/></ItemsPanelTemplate>
                </ComboBox.ItemsPanel>
            </ComboBox>
            <Button Grid.Column="1" Content="Load" Command="{Binding LoadVoicesCommand}" Width="50" Margin="4,0,0,0"/>
        </Grid>

        <TextBlock Grid.Row="3" Grid.Column="0" Text="Pitch:" VerticalAlignment="Center" Margin="0,6"/>
        <Slider Grid.Row="3" Grid.Column="1" Minimum="-100" Maximum="100" Value="{Binding Pitch}" Margin="0,4" TickFrequency="10" IsSnapToTickEnabled="True"/>

        <TextBlock Grid.Row="4" Grid.Column="0" Text="Rate:" VerticalAlignment="Center" Margin="0,6"/>
        <Slider Grid.Row="4" Grid.Column="1" Minimum="-100" Maximum="100" Value="{Binding Rate}" Margin="0,4" TickFrequency="10" IsSnapToTickEnabled="True"/>

        <TextBlock Grid.Row="5" Grid.Column="0" Text="Volume:" VerticalAlignment="Center" Margin="0,6"/>
        <Slider Grid.Row="5" Grid.Column="1" Minimum="0" Maximum="100" Value="{Binding Volume}" Margin="0,4"/>

        <TextBlock Grid.Row="6" Grid.Column="0" Text="Output Device:" VerticalAlignment="Center" Margin="0,6"/>
        <ComboBox Grid.Row="6" Grid.Column="1" ItemsSource="{Binding OutputDevices}" SelectedValuePath="Id" DisplayMemberPath="Name" SelectedValue="{Binding OutputDeviceId}" Margin="0,4"/>

        <StackPanel Grid.Row="9" Grid.Column="0" Grid.ColumnSpan="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Content="OK" Width="80" IsDefault="True" Click="OkButton_Click" Margin="0,0,8,0"/>
            <Button Content="Cancel" Width="80" IsCancel="True"/>
        </StackPanel>
    </Grid>
</Window>
