<Window x:Class="OpenSpeaker.Views.GenericSpeakerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Generic Speaker" Width="560" Height="530"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="{StaticResource Bg1}"
        Foreground="{StaticResource TextPrimary}">
    <DockPanel Margin="16">

        <GroupBox DockPanel.Dock="Top" Header="SETTINGS" Margin="0,0,0,10">
            <StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                    <TextBlock Text="Voice" Style="{StaticResource MutedText}" VerticalAlignment="Center" Width="42"/>
                    <ComboBox x:Name="VoiceComboBox"
                              ItemsSource="{Binding Voices}" SelectedItem="{Binding SelectedVoice}"
                              Tag="{Binding VoiceFilter, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                              Width="380"
                              ScrollViewer.CanContentScroll="True"
                              MaxDropDownHeight="300">
                        <ComboBox.ItemsPanel>
                            <ItemsPanelTemplate><VirtualizingStackPanel IsVirtualizing="True" VirtualizationMode="Recycling"/></ItemsPanelTemplate>
                        </ComboBox.ItemsPanel>
                    </ComboBox>
                </StackPanel>

                <DockPanel Margin="0,0,0,6">
                    <Button DockPanel.Dock="Right" Content="Reset" Command="{Binding ResetVolumeCommand}"
                            Padding="10,5" Margin="8,0,0,0"/>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="Volume" Style="{StaticResource MutedText}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <Slider Minimum="0" Maximum="100" Value="{Binding Volume}" Width="180" VerticalAlignment="Center"/>
                        <TextBlock VerticalAlignment="Center" Margin="8,0,0,0" Width="40">
                            <Run Text="{Binding Volume, Mode=OneWay}"/>
                            <Run Text="%"/>
                        </TextBlock>
                    </StackPanel>
                </DockPanel>

                <ItemsControl ItemsSource="{Binding ParamRows}" VerticalAlignment="Center">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel Orientation="Horizontal"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal" Margin="0,0,10,0" VerticalAlignment="Center">
                                <TextBlock Text="{Binding Def.Label}" Style="{StaticResource MutedText}"
                                           VerticalAlignment="Center" Margin="0,0,5,0"/>
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center"
                                            Visibility="{Binding IsSlider, Converter={StaticResource BoolToVisibilityConverter}}">
                                    <Slider Value="{Binding SliderValue, Mode=TwoWay}"
                                            Minimum="{Binding Def.Min}" Maximum="{Binding Def.Max}"
                                            SmallChange="{Binding Def.Step}" LargeChange="{Binding Def.Step}"
                                            TickFrequency="{Binding Def.Step}" IsSnapToTickEnabled="True"
                                            Width="70" VerticalAlignment="Center"/>
                                    <TextBlock Text="{Binding DisplayValue}" VerticalAlignment="Center"
                                               Margin="4,0,0,0" Width="32" FontFamily="Consolas" FontSize="11"/>
                                </StackPanel>
                                <ComboBox ItemsSource="{Binding Def.Options}" SelectedItem="{Binding Value}"
                                          Width="150" VerticalAlignment="Center"
                                          Visibility="{Binding IsComboBox, Converter={StaticResource BoolToVisibilityConverter}}"/>
                            </StackPanel>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </GroupBox>

        <TextBlock DockPanel.Dock="Top" Text="TEXT TO SPEAK" Style="{StaticResource SectionLabel}" Margin="0,0,0,4"/>
        <TextBox DockPanel.Dock="Top"
                 Text="{Binding Text, UpdateSourceTrigger=PropertyChanged}"
                 Height="120" AcceptsReturn="True" TextWrapping="Wrap"
                 VerticalScrollBarVisibility="Auto"
                 VerticalContentAlignment="Top"
                 Margin="0,0,0,10"/>

        <Button DockPanel.Dock="Top" Content="Speak" Command="{Binding SpeakCommand}"
                Style="{StaticResource AccentButton}"
                Height="36" FontSize="14" Margin="0,0,0,8"/>

        <TextBlock DockPanel.Dock="Top" Text="{Binding Status, Mode=OneWay}"
                   Style="{StaticResource MutedText}" Margin="0,0,0,8"/>

        <TextBlock DockPanel.Dock="Top" Text="SPOKEN PREVIEWS" Style="{StaticResource SectionLabel}" Margin="0,0,0,4"/>
        <ListBox ItemsSource="{Binding SpokenPreviews}"
                 Background="{StaticResource Bg2}" BorderBrush="{StaticResource BorderBrush0}" BorderThickness="1">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <TextBlock Text="{Binding}" FontFamily="Segoe UI" FontSize="12"/>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

    </DockPanel>
</Window>
